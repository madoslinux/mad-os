# Generated by iptables-save
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Loopback
-A INPUT -i lo -j ACCEPT

# Established connections
-A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# ICMP
-A INPUT -p icmp -j ACCEPT

# SSH - localhost and private networks only
-A INPUT -s 127.0.0.0/8 -p tcp --dport 22 -j ACCEPT
-A INPUT -s 10.0.0.0/8 -p tcp --dport 22 -j ACCEPT
-A INPUT -s 172.16.0.0/12 -p tcp --dport 22 -j ACCEPT
-A INPUT -s 192.168.0.0/16 -p tcp --dport 22 -j ACCEPT

# Local network services (optional)
-A INPUT -s 127.0.0.0/8 -p udp --dport 53 -j ACCEPT
-A INPUT -s 10.0.0.0/8 -p udp --dport 53 -j ACCEPT
-A INPUT -s 172.16.0.0/12 -p udp --dport 53 -j ACCEPT
-A INPUT -s 192.168.0.0/16 -p udp --dport 53 -j ACCEPT

COMMIT
