# /etc/ufw/user.rules
# UFW user rules - allow essential services

*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Allow loopback
-A INPUT -i lo -j ACCEPT
-A OUTPUT -o lo -j ACCEPT

# Allow established connections
-A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# Allow SSH (important for remote access)
-A INPUT -p tcp --dport 22 -m state --state NEW -m recent --set --name SSH
-A INPUT -p tcp --dport 22 -m state --state NEW -m recent --update --seconds 60 --hitcount 4 --name SSH -j DROP
-A INPUT -p tcp --dport 22 -m state --state NEW -j ACCEPT

# Allow mDNS (Avahi/Zeroconf)
-A INPUT -p udp --dport 5353 -j ACCEPT

# Allow CUPS (printing)
-A INPUT -p tcp --dport 631 -j ACCEPT

# Allow Syncthing
-A INPUT -p tcp --dport 22000 -j ACCEPT
-A INPUT -p udp --dport 21027 -j ACCEPT

# Allow WireGuard (VPN)
-A INPUT -p udp --dport 51820 -j ACCEPT

# Allow Ollama API (local AI)
-A INPUT -p tcp --dport 11434 -j ACCEPT -s 127.0.0.1
-A INPUT -p tcp --dport 11434 -j ACCEPT -s 192.168.0.0/16
-A INPUT -p tcp --dport 11434 -j ACCEPT -s 10.0.0.0/8

# Allow Docker (if installed)
-A INPUT -p tcp --dport 2375 -j DROP
-A INPUT -p tcp --dport 2376 -j DROP

# Reject anything not explicitly allowed
-A INPUT -j REJECT --reject-with icmp-host-prohibited
-A FORWARD -j REJECT --reject-with icmp-host-prohibited

COMMIT