# Sudo sin password para Ollama y OpenCode
# Solo usuarios con privilegios sudo (grupo wheel) pueden ejecutar estos comandos
%wheel ALL=(ALL:ALL) NOPASSWD: /usr/bin/ollama, /usr/local/bin/ollama, /usr/bin/opencode, /usr/local/bin/opencode

# Preservar variables de entorno Wayland para aplicaciones GTK ejecutadas con sudo
Defaults env_keep += "WAYLAND_DISPLAY XDG_RUNTIME_DIR DISPLAY SWAYSOCK"
