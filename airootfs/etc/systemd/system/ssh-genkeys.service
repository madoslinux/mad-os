[Unit]
Description=Generate SSH host keys
Before=sshd.service
DefaultDependencies=no
Conflicts=shutdown.target
After=systemd-remount-fs.service

[Service]
Type=oneshot
ExecStartPre=/bin/sh -c '[ -f /etc/ssh/ssh_host_rsa_key ] || /usr/bin/ssh-keygen -A'
ExecStart=/bin/touch /run/sshd-ready
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
