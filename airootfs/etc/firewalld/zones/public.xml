<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>Public</short>
  <description>For use in public areas. Blocks LAN and only allows essential services.</description>
  <service name="ssh"/>
  <service name="dhcpv6-client"/>
  <port port="41641" protocol="udp"/>
  <!-- Block private networks (LAN) -->
  <rule family="ipv4">
    <source address="10.0.0.0/8"/>
    <drop/>
  </rule>
  <rule family="ipv4">
    <source address="172.16.0.0/12"/>
    <drop/>
  </rule>
  <rule family="ipv4">
    <source address="192.168.0.0/16"/>
    <drop/>
  </rule>
  <rule family="ipv6">
    <source address="fd00::/8"/>
    <drop/>
  </rule>
</zone>
