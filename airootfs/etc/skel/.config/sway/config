# Sway Configuration - Clean & Professional
# ==========================================

### Variables
set $mod Mod4

# DPI y scaling para aplicaciones - Reduce tamaño de fuentes
set $gnome-schema org.gnome.desktop.interface

# Ejecutar solo al inicio (no en cada reload)
exec {
    gsettings set $gnome-schema gtk-theme "$(grep -m1 '^gtk-theme-name=' ~/.config/gtk-3.0/settings.ini 2>/dev/null | cut -d= -f2 || echo Nordic)"
    gsettings set $gnome-schema icon-theme "$(grep -m1 '^gtk-icon-theme-name=' ~/.config/gtk-3.0/settings.ini 2>/dev/null | cut -d= -f2 || echo Nordzy-dark)"
    gsettings set $gnome-schema color-scheme 'prefer-dark'
    gsettings set $gnome-schema text-scaling-factor 0.75
    gsettings set $gnome-schema cursor-theme "$(grep -m1 '^gtk-cursor-theme-name=' ~/.config/gtk-3.0/settings.ini 2>/dev/null | cut -d= -f2 || echo Adwaita)"
    gsettings set $gnome-schema cursor-size "$(grep -m1 '^gtk-cursor-theme-size=' ~/.config/gtk-3.0/settings.ini 2>/dev/null | cut -d= -f2 || echo 16)"
    gsettings set $gnome-schema font-name "$(grep -m1 '^gtk-font-name=' ~/.config/gtk-3.0/settings.ini 2>/dev/null | cut -d= -f2 || echo 'JetBrainsMono Nerd Font 10')"
    systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
    hash dbus-update-activation-environment 2>/dev/null && \
         dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
    # Iniciar servicios de audio PipeWire (socket-activated)
    systemctl --user enable --now pipewire.socket pipewire-pulse.socket wireplumber.service
}

# Vim-style directional keys
set $left h
set $down j
set $up k
set $right l

# Applications
set $term foot
set $menu wofi --show drun

# Color Scheme - Nord-inspired Professional
set $bg-color            #2E3440
set $inactive-bg-color   #3B4252
set $text-color          #ECEFF4
set $inactive-text-color #D8DEE9
set $urgent-bg-color     #BF616A
set $accent-color        #88C0D0
set $border-color        #4C566A
set $indicator-color     #81A1C1

### Output Configuration
# Brief placeholder background (overridden by mados-wallpaperd on startup)
output * bg #2E3440 solid_color

# Initialize wallpaper daemons
exec swww-daemon
exec mados-wallpaperd -d

# Display scaling - adjust scale value to your preference
# scale 1.0 = 100% (default), 0.8 = 80% (smaller), 0.75 = 75% (even smaller)
# Fractional scaling can cause issues with some apps, use 1.0 for compatibility
# Get display names with: swaymsg -t get_outputs
# output LVDS-1 scale 1.0
# output Virtual-1 scale 1.0

# Uncomment and adjust for your displays
# Get display names with: swaymsg -t get_outputs
# output HDMI-A-1 resolution 1920x1080 position 1920,0

### Input Configuration

# Keyboard - Spanish layout
input type:keyboard {
    xkb_layout "es"
    # Caps Lock as Escape (optional)
    xkb_options "caps:escape"
}

# Touchpad configuration (if applicable)
input type:touchpad {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
}

### Window Appearance

# Gaps - Reducidos para mejor rendimiento
gaps inner 2
gaps outer 0

# Borders - Reducidos para ahorrar RAM
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

# Window colors          border              background          text                indicator           child_border
client.focused           $accent-color       $bg-color           $text-color         $indicator-color    $accent-color
client.focused_inactive  $border-color       $inactive-bg-color  $inactive-text-color $border-color      $border-color
client.unfocused         $border-color       $inactive-bg-color  $inactive-text-color $border-color      $border-color
client.urgent            $urgent-bg-color    $urgent-bg-color    $text-color         $urgent-bg-color    $urgent-bg-color

### Key Bindings

# Basics
bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+d exec $menu
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Salir de Sway?' -B 'Sí, salir' 'swaymsg exit'

# Floating windows
floating_modifier $mod normal

# Moving around - Vim keys
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Moving around - Arrow keys
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move windows - Vim keys
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# Move windows - Arrow keys
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Workspaces (each binding also triggers wallpaper change)
bindsym $mod+1 workspace number 1; exec mados-wallpaperd set 1
bindsym $mod+2 workspace number 2; exec mados-wallpaperd set 2
bindsym $mod+3 workspace number 3; exec mados-wallpaperd set 3
bindsym $mod+4 workspace number 4; exec mados-wallpaperd set 4
bindsym $mod+5 workspace number 5; exec mados-wallpaperd set 5
bindsym $mod+6 workspace number 6; exec mados-wallpaperd set 6

# Switch workspaces with Super+Alt+arrows (cycles 1-5 with wrap-around)
bindsym $mod+Mod1+Left exec mados-sway-workspace-cycle prev
bindsym $mod+Mod1+Right exec mados-sway-workspace-cycle next

# Move to workspaces
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5

# Layout
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e exec pcmanfm
bindsym $mod+f fullscreen

# Floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Resize mode
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### Utilities

# Audio (PipeWire)
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1.0
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

# On-screen keyboard toggle
bindsym $mod+F12 exec mados-squeekboard toggle

# Screenshots - Using grim/slurp (native Wayland, works on Sway)
# Ensure Pictures/Screenshots directory exists
exec_always --no-startup-id mkdir -p ~/Pictures/Screenshots

# Screenshot bindings
bindsym Print exec grim -g "$(slurp)" ~/Pictures/Screenshots/Screenshot-$(date +%Y-%m-%d-%H-%M-%S).png
bindsym Shift+Print exec grim ~/Pictures/Screenshots/Screenshot-$(date +%Y-%m-%d-%H-%M-%S).png
bindsym Ctrl+Print exec grim -g "$(swaymsg -t get_tree | jq -r '.. | select(.focused?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"')" ~/Pictures/Screenshots/Screenshot-$(date +%Y-%m-%d-%H-%M-%S).png
bindsym $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy

### Startup Applications

# Waybar
exec_always --no-startup-id "pkill waybar || true; sleep 0.3; waybar"

# WiFi tray applet (NetworkManager)
exec --no-startup-id nm-applet --indicator

# Bluetooth tray applet (Blueman)
exec --no-startup-id blueman-applet

# madOS Application Launcher dock
exec --no-startup-id mados-launcher

# Steam Deck / Gamepad → WM bridge (translates gamepad buttons to sway commands)
# Only activates when a gamepad is detected; exits cleanly if none found
exec --no-startup-id mados-gamepad-wm --compositor sway

# On-screen keyboard (squeekboard) — auto-activates when no physical keyboard detected
exec --no-startup-id mados-squeekboard auto

# VirtualBox Guest Additions (auto-resize, clipboard, drag-and-drop)
# Only runs when inside a VirtualBox VM, exits immediately otherwise
exec --no-startup-id mados-vbox-guest

# Xwayland (for maim screenshots)
exec_always --no-startup-id "pgrep Xwayland || echo 'Xwayland should auto-start'"

# Notification daemon (optional, uncomment if mako is installed)
# exec_always --no-startup-id mako

### madOS Application Window Rules
# Photo Viewer - floating for better image viewing
for_window [app_id="mados-photo-viewer"] floating enable
for_window [app_id="mados-photo-viewer"] resize set 900 700

# PDF Viewer - floating for document viewing
for_window [app_id="mados-pdf-viewer"] floating enable
for_window [app_id="mados-pdf-viewer"] resize set 900 700

# Audio Equalizer - floating utility
for_window [app_id="mados-equalizer"] floating enable
for_window [app_id="mados-equalizer"] resize set 750 450

# Squeekboard on-screen keyboard — keep at bottom, no focus steal
for_window [app_id="sm.puri.Squeekboard"] floating enable
no_focus [app_id="sm.puri.Squeekboard"]

### System includes
include /etc/sway/config.d/*
