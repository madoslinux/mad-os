{
    "layer": "top",
    "position": "top",
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "hyprland/workspaces",
        "hyprland/submap",
        "niri/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "network",
        "cpu",
        "memory",
        "pulseaudio",
        "backlight",
        "battery",
        "custom/help",
        "custom/power"
    ],
    "sway/workspaces": {
        "format": "{name}",
        "disable-scroll": false,
        "all-outputs": true,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        },
        "on-click": "mados-wallpaperd set {}"
    },
    "sway/mode": {
        "format": "<span style=\"italic\">󰕷  {}</span>",
        "tooltip": false
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "all-outputs": true,
        "active-only": false,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        },
        "on-click": "mados-wallpaperd set {}"
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">󰕷  {}</span>",
        "tooltip": false
    },
    "niri/workspaces": {
        "format": "{name}",
        "all-outputs": true,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        },
        "on-click": "mados-wallpaperd set {}"
    },
    "clock": {
        "format": "<span size='x-large'>󰥔</span>  {:%a %d %b  %H:%M}",
        "format-alt": "<span size='x-large'>󰃭</span>  {:%Y-%m-%d  %H:%M:%S}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#81A1C1'><b>{}</b></span>",
                "days": "<span color='#D8DEE9'><b>{}</b></span>",
                "weeks": "<span color='#5E81AC'><b>W{}</b></span>",
                "weekdays": "<span color='#88C0D0'><b>{}</b></span>",
                "today": "<span color='#BF616A'><b><u>{}</u></b></span>"
            }
        },
        "interval": 1
    },
    "cpu": {
        "format": "<span size='x-large'>󰻠</span>  {usage}%",
        "tooltip": false,
        "interval": 3,
        "on-click": "foot -e btop"
    },
    "memory": {
        "format": "<span size='x-large'>󰍛</span>  {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G used",
        "interval": 5,
        "on-click": "foot -e btop"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "network": {
        "format-wifi": "<span size='x-large'>󰤨</span>  {essid}",
        "format-ethernet": "<span size='x-large'>󰈀</span>  {ipaddr}",
        "format-disconnected": "<span size='x-large'>󰤭</span>  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "<span size='x-large'>{icon}</span>  {volume}%",
        "format-muted": "<span size='x-large'>󰝟</span>  Muted",
        "format-icons": {
            "headphone": "󰋋",
            "hands-free": "󰋎",
            "headset": "󰋎",
            "phone": "󰄜",
            "portable": "󰄜",
            "car": "󰄜",
            "default": [
                "󰕿",
                "󰖀",
                "󰕾"
            ]
        },
        "on-click": "mados-equalizer",
        "on-click-right": "pavucontrol",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1.0",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "smooth-scrolling-threshold": 1
    },
    "backlight": {
        "format": "<span size='x-large'>{icon}</span>  {percent}%",
        "format-icons": [
            "󰃞",
            "󰃟",
            "󰃠"
        ],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "<span size='x-large'>{icon}</span>  {capacity}%",
        "format-charging": "<span size='x-large'>󰂄</span>  {capacity}%",
        "format-plugged": "<span size='x-large'>󰚥</span>  {capacity}%",
        "format-alt": "<span size='x-large'>{icon}</span>  {time}",
        "format-icons": [
            "󰂎",
            "󰁺",
            "󰁻",
            "󰁼",
            "󰁽",
            "󰁾",
            "󰁿",
            "󰂀",
            "󰂁",
            "󰂂",
            "󰁹"
        ],
        "tooltip-format": "{capacity}% • {timeTo}"
    },
    "custom/help": {
        "format": "?",
        "on-click": "/usr/local/bin/mados-help",
        "tooltip": false
    },
    "custom/power": {
        "format": "⏻",
        "on-click": "/usr/local/bin/mados-power",
        "tooltip": false
    }
}