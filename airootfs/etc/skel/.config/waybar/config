{
    "layer": "top",
    "position": "top",
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "modules-left": [
        "custom/launcher",
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "network",
        "cpu",
        "memory",
        "pulseaudio",
        "backlight",
        "battery",
        "custom/help",
        "custom/power"
    ],
    "sway/workspaces": {
        "format": "{name}{windows}",
        "format-window-separator": "",
        "window-rewrite-default": " βÄΔ",
        "disable-scroll": false,
        "all-outputs": true,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">σΑïΖ  {}</span>",
        "tooltip": false
    },
    "clock": {
        "format": "<span size='x-large'>σΑΞî</span>  {:%a %d %b  %H:%M}",
        "format-alt": "<span size='x-large'>σΑÉ≠</span>  {:%Y-%m-%d  %H:%M:%S}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#81A1C1'><b>{}</b></span>",
                "days": "<span color='#D8DEE9'><b>{}</b></span>",
                "weeks": "<span color='#5E81AC'><b>W{}</b></span>",
                "weekdays": "<span color='#88C0D0'><b>{}</b></span>",
                "today": "<span color='#BF616A'><b><u>{}</u></b></span>"
            }
        },
        "interval": 1
    },
    "cpu": {
        "format": "<span size='x-large'>σΑΜ†</span>  {usage}%",
        "tooltip": false,
        "interval": 3,
        "on-click": "foot -e btop"
    },
    "memory": {
        "format": "<span size='x-large'>σΑç¦</span>  {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G used",
        "interval": 5,
        "on-click": "foot -e btop"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "network": {
        "format-wifi": "<span size='x-large'>σΑΛ®</span>  {essid}",
        "format-ethernet": "<span size='x-large'>σΑàÄ</span>  {ipaddr}",
        "format-disconnected": "<span size='x-large'>σΑΛ≠</span>  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "bash -c 'export WAYLAND_DISPLAY=$WAYLAND_DISPLAY && export DISPLAY=$DISPLAY && $HOME/.config/waybar/scripts/network.sh'"
    },
    "pulseaudio": {
        "format": "<span size='x-large'>{icon}</span>  {volume}%",
        "format-muted": "<span size='x-large'>σΑùü</span>  Muted",
        "format-icons": {
            "headphone": "σΑ΄΄",
            "hands-free": "σΑ΄é",
            "headset": "σΑ΄é",
            "phone": "σΑ³€",
            "portable": "σΑ³€",
            "car": "σΑ³€",
            "default": [
                "σΑïΩ",
                "σΑ•Ä",
                "σΑïΨ"
            ]
        },
        "on-click": "mados-equalizer",
        "on-click-right": "pavucontrol",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1.0",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "smooth-scrolling-threshold": 1
    },
    "backlight": {
        "format": "<span size='x-large'>{icon}</span>  {percent}%",
        "format-icons": [
            "σΑÉû",
            "σΑÉü",
            "σΑÉ†"
        ],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "<span size='x-large'>{icon}</span>  {capacity}%",
        "format-charging": "<span size='x-large'>σΑ²³</span>  {capacity}%",
        "format-plugged": "<span size='x-large'>σΑöΞ</span>  {capacity}%",
        "format-alt": "<span size='x-large'>{icon}</span>  {time}",
        "format-icons": [
            "σΑ²é",
            "σΑ¹Κ",
            "σΑ¹Μ",
            "σΑ¹Φ",
            "σΑ¹Ϋ",
            "σΑ¹Ψ",
            "σΑ¹Ω",
            "σΑ²Ä",
            "σΑ²¹",
            "σΑ²²",
            "σΑ¹Ι"
        ],
        "tooltip-format": "{capacity}% βÄΔ {timeTo}"
    },
    "custom/launcher": {
        "format": "σΑΘ΅",
        "on-click": "bash -c 'export WAYLAND_DISPLAY=$WAYLAND_DISPLAY && export DISPLAY=$DISPLAY && wofi --show drun'",
        "tooltip": false
    },
    "custom/help": {
        "format": "?",
        "on-click": "bash -c 'export WAYLAND_DISPLAY=$WAYLAND_DISPLAY && export DISPLAY=$DISPLAY && /usr/local/bin/mados-help'",
        "tooltip": false
    },
    "custom/power": {
        "format": "βèΜ",
        "on-click": "bash -c 'export WAYLAND_DISPLAY=$WAYLAND_DISPLAY && export DISPLAY=$DISPLAY && /usr/local/bin/mados-power'",
        "tooltip": false
    }
}
