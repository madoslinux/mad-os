#!/usr/bin/env python3

import argparse
import hashlib
import json
import os
import shutil
import time
from pathlib import Path

DEFAULT_SOURCES = [
    "~/Images/Wallpapers",
    "~/.local/share/mados/wallpapers",
    "~/Pictures/Wallpapers",
    "/usr/share/backgrounds",
    "/usr/share/wallpapers",
    "/usr/share/mados/wallpapers",
    "/opt/mados/mados_wallpaper",
]

EXCLUDED_SOURCE_PATHS = [
    "/usr/share/backgrounds/sway",
]

IMAGE_EXTENSIONS = {
    ".jpg",
    ".jpeg",
    ".png",
    ".webp",
    ".gif",
    ".bmp",
    ".tif",
    ".tiff",
}

VIDEO_EXTENSIONS = {
    ".mp4",
    ".mkv",
    ".mov",
    ".webm",
    ".avi",
}

SYNC_THROTTLE_SECONDS = 900
FINGERPRINT_CHUNK_SIZE = 131072


def home() -> Path:
    return Path.home()


def config_file() -> Path:
    xdg = os.environ.get("XDG_CONFIG_HOME", str(home() / ".config"))
    return Path(xdg) / "skwd-wall" / "config.json"


def cache_root() -> Path:
    xdg = os.environ.get("XDG_CACHE_HOME", str(home() / ".cache"))
    return Path(xdg) / "skwd-wall"


def union_dir() -> Path:
    return cache_root() / "wallpaper-union"


def sync_state_file() -> Path:
    return cache_root() / "source-sync-state.json"


def normalize(path: str) -> str:
    value = os.path.expandvars(path.strip())
    value = os.path.expanduser(value)
    return str(Path(value).resolve())


def save_config(data: dict) -> None:
    path = config_file()
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=4, ensure_ascii=False) + "\n")


def load_sync_state() -> dict:
    path = sync_state_file()
    if not path.is_file():
        return {}

    try:
        data = json.loads(path.read_text())
    except json.JSONDecodeError:
        return {}

    return data if isinstance(data, dict) else {}


def save_sync_state(state: dict) -> None:
    path = sync_state_file()
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(state, indent=2, ensure_ascii=False) + "\n")


def source_marker(source: str) -> str:
    path = Path(source)
    if not path.exists():
        return f"{source}|missing"

    try:
        stats = path.stat()
    except OSError:
        return f"{source}|stat_error"

    top_level_entries = 0
    if path.is_dir():
        try:
            top_level_entries = sum(1 for _ in path.iterdir())
        except OSError:
            top_level_entries = 0

    return f"{source}|{int(stats.st_mtime_ns)}|{top_level_entries}"


def sources_signature(sources: list[str]) -> str:
    payload = "\n".join(source_marker(source) for source in sources)
    return hashlib.sha1(payload.encode("utf-8")).hexdigest()


def should_rebuild(sources: list[str], force: bool = False) -> bool:
    if force:
        return True

    union = union_dir()
    if not union.exists():
        return True

    try:
        if not any(union.iterdir()):
            return True
    except OSError:
        return True

    state = load_sync_state()
    if not state:
        return True

    previous_sources = state.get("sources")
    previous_signature = state.get("signature")
    previous_synced_at = float(state.get("synced_at", 0))

    signature = sources_signature(sources)
    if previous_sources == sources and previous_signature == signature:
        if time.time() - previous_synced_at < SYNC_THROTTLE_SECONDS:
            return False
        return False

    return True


def prepare_sources() -> list[str]:
    data = ensure_config()
    paths = data.get("paths", {})
    sources = [s for s in paths.get("wallpaperSources", []) if isinstance(s, str)]
    cache_root().mkdir(parents=True, exist_ok=True)
    union_dir().mkdir(parents=True, exist_ok=True)
    return sources


def ensure_config() -> dict:
    path = config_file()
    path.parent.mkdir(parents=True, exist_ok=True)

    if not path.is_file():
        install_dir = Path("/usr/local/share/skwd-wall")
        example = install_dir / "data" / "config.json.example"
        if example.is_file():
            data = json.loads(example.read_text())
        else:
            data = {}
    else:
        try:
            data = json.loads(path.read_text())
        except json.JSONDecodeError:
            data = {}

    if not isinstance(data, dict):
        data = {}

    paths = data.get("paths")
    if not isinstance(paths, dict):
        paths = {}
    data["paths"] = paths

    sources = paths.get("wallpaperSources")
    if not isinstance(sources, list):
        sources = []

    merged = []
    seen = set()

    legacy = paths.get("wallpaper")
    if isinstance(legacy, str) and legacy.strip():
        legacy_norm = normalize(legacy)
        if legacy_norm not in seen and not legacy_norm.endswith("/wallpaper-union"):
            merged.append(legacy_norm)
            seen.add(legacy_norm)

    for item in sources:
        if isinstance(item, str) and item.strip():
            norm = normalize(item)
            if norm not in seen:
                merged.append(norm)
                seen.add(norm)

    for item in DEFAULT_SOURCES:
        norm = normalize(item)
        if norm not in seen:
            merged.append(norm)
            seen.add(norm)

    paths["wallpaperSources"] = merged
    paths["wallpaper"] = str(union_dir())
    if not isinstance(paths.get("videoWallpaper"), str) or not str(paths["videoWallpaper"]).strip():
        paths["videoWallpaper"] = str(union_dir())

    data["compositor"] = "hyprland"
    save_config(data)
    return data


def iter_files(source: Path):
    excluded_paths = [Path(item) for item in EXCLUDED_SOURCE_PATHS]
    for path in source.rglob("*"):
        if path.is_file():
            if any(path.is_relative_to(excluded) for excluded in excluded_paths):
                continue
            ext = path.suffix.lower()
            if ext in IMAGE_EXTENSIONS or ext in VIDEO_EXTENSIONS:
                yield path


def file_fingerprint(path: Path) -> str:
    """Return a stable lightweight content fingerprint for deduplication."""
    try:
        stats = path.stat()
    except OSError:
        return ""

    hasher = hashlib.sha1()
    hasher.update(str(stats.st_size).encode("utf-8"))

    try:
        with path.open("rb") as handle:
            head = handle.read(FINGERPRINT_CHUNK_SIZE)
            hasher.update(head)

            if stats.st_size > FINGERPRINT_CHUNK_SIZE:
                tail_offset = max(0, stats.st_size - FINGERPRINT_CHUNK_SIZE)
                handle.seek(tail_offset)
                tail = handle.read(FINGERPRINT_CHUNK_SIZE)
                hasher.update(tail)
    except OSError:
        return ""

    return hasher.hexdigest()


def build_union_from_sources(sources: list[str]) -> None:
    target = union_dir()
    parent = target.parent
    temp = parent / (target.name + ".tmp")
    old = parent / (target.name + ".old")

    shutil.rmtree(temp, ignore_errors=True)
    temp.mkdir(parents=True, exist_ok=True)

    seen_targets: set[str] = set()
    seen_fingerprints: set[str] = set()

    for src in sources:
        source = Path(src)
        if not source.is_dir():
            continue

        for item in iter_files(source):
            try:
                resolved = str(item.resolve())
            except OSError:
                resolved = str(item)

            if resolved in seen_targets:
                continue

            fingerprint = file_fingerprint(item)
            if fingerprint and fingerprint in seen_fingerprints:
                continue

            digest = hashlib.sha1(str(item).encode("utf-8")).hexdigest()[:10]
            stem = item.stem or "wallpaper"
            safe = "".join(ch if ch.isalnum() or ch in "-_" else "_" for ch in stem)[:80]
            name = f"{safe}__{digest}{item.suffix.lower()}"
            link = temp / name
            if not link.exists():
                try:
                    link.symlink_to(item)
                    seen_targets.add(resolved)
                    if fingerprint:
                        seen_fingerprints.add(fingerprint)
                except OSError:
                    pass

    shutil.rmtree(old, ignore_errors=True)
    if target.exists() or target.is_symlink():
        target.rename(old)
    temp.rename(target)
    shutil.rmtree(old, ignore_errors=True)


def load_sources() -> list[str]:
    data = ensure_config()
    paths = data.get("paths", {})
    sources = paths.get("wallpaperSources", [])
    return [s for s in sources if isinstance(s, str)]


def cmd_sync(force: bool = False) -> int:
    sources = prepare_sources()
    if not should_rebuild(sources, force=force):
        return 0

    build_union_from_sources(sources)
    save_sync_state(
        {
            "sources": sources,
            "signature": sources_signature(sources),
            "synced_at": int(time.time()),
        }
    )
    return 0


def cmd_prepare() -> int:
    prepare_sources()
    return 0


def cmd_list() -> int:
    for entry in load_sources():
        print(entry)
    return 0


def cmd_add(path: str) -> int:
    data = ensure_config()
    paths = data["paths"]
    sources = [s for s in paths.get("wallpaperSources", []) if isinstance(s, str)]
    norm = normalize(path)
    if norm not in sources:
        sources.append(norm)
        paths["wallpaperSources"] = sources
        save_config(data)
    build_union_from_sources(sources)
    save_sync_state(
        {
            "sources": sources,
            "signature": sources_signature(sources),
            "synced_at": int(time.time()),
        }
    )
    return 0


def cmd_remove(path: str) -> int:
    data = ensure_config()
    paths = data["paths"]
    sources = [s for s in paths.get("wallpaperSources", []) if isinstance(s, str)]
    norm = normalize(path)
    paths["wallpaperSources"] = [s for s in sources if s != norm]
    save_config(data)
    build_union_from_sources(paths["wallpaperSources"])
    save_sync_state(
        {
            "sources": paths["wallpaperSources"],
            "signature": sources_signature(paths["wallpaperSources"]),
            "synced_at": int(time.time()),
        }
    )
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Manage skwd-wall wallpaper sources")
    sub = parser.add_subparsers(dest="cmd")

    sub.add_parser("sync")
    sub.add_parser("prepare")
    sub.add_parser("list")
    add_p = sub.add_parser("add")
    add_p.add_argument("path")
    rm_p = sub.add_parser("remove")
    rm_p.add_argument("path")

    args = parser.parse_args()
    if args.cmd in {None, "sync"}:
        return cmd_sync()
    if args.cmd == "prepare":
        return cmd_prepare()
    if args.cmd == "list":
        return cmd_list()
    if args.cmd == "add":
        return cmd_add(args.path)
    if args.cmd == "remove":
        return cmd_remove(args.path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
