#!/usr/bin/env python3

import gi
import os

gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk, GLib

help_data = [
    (
        "General",
        [
            ("Super + Return", "Open terminal (kitty)"),
            ("Super + D", "Open app launcher (wofi)"),
            ("Super + Q", "Close window"),
            ("Super + E", "Open file manager"),
            ("Super + F", "Toggle fullscreen"),
            ("Super+Shift+E", "Exit Hyprland"),
        ],
    ),
    (
        "Workspaces",
        [
            ("Super + 1-5", "Switch to workspace"),
            ("Super+Shift+1-5", "Move window to workspace"),
            ("Super+Alt+←/→", "Cycle workspaces"),
        ],
    ),
    (
        "Navigation",
        [
            ("Super+H/J/K/L", "Move focus (vim keys)"),
            ("Super+Arrows", "Move focus (arrows)"),
            ("Super + A", "Focus urgent/last"),
        ],
    ),
    (
        "Window Mgmt",
        [
            ("Super+Space", "Cycle next window"),
            ("Super+Shift+Space", "Toggle floating"),
            ("Super + B", "Preselect right"),
            ("Super + V", "Preselect down"),
            ("Super + S", "Pseudo tile"),
            ("Super + W", "Toggle split"),
        ],
    ),
    (
        "Resize Mode",
        [
            ("Super + R", "Enter resize mode"),
            ("H/J/K/L", "Resize window"),
            ("Esc/Return", "Exit resize mode"),
        ],
    ),
    (
        "Scratchpad",
        [
            ("Super + -", "Toggle scratchpad"),
            ("Super+Shift+-", "Move to scratchpad"),
        ],
    ),
    (
        "Screenshots",
        [
            ("Print", "Screenshot selection"),
            ("Shift+Print", "Screenshot fullscreen"),
            ("Super+Shift+S", "Screenshot to clipboard"),
        ],
    ),
    (
        "Multimedia",
        [
            ("XF86AudioMute", "Toggle mute"),
            ("XF86Audio-", "Volume down"),
            ("XF86Audio+", "Volume up"),
            ("XF86Bright-", "Brightness down"),
            ("XF86Bright+", "Brightness up"),
        ],
    ),
]

css_provider = """
* { font-family: monospace; font-size: 12px; }
window { background: #2E3440; }
.key-label { background: #3B4252; border: 1px solid #4C566A; border-radius: 4px; padding: 2px 6px; }
"""

COLUMN_THRESHOLD_2 = 500
COLUMN_THRESHOLD_3 = 900


def create_help_window():
    window = Gtk.Window()
    window.set_title("MadOS Help")
    window.set_default_size(450, 500)
    window.set_resizable(True)

    css = Gtk.CssProvider()
    css.load_from_string(css_provider)
    display = Gdk.Display.get_default()
    Gtk.StyleContext.add_provider_for_display(display, css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    header = Gtk.Label()
    header.set_markup(
        "<span size='large' weight='bold' color='#88C0D0'>⌨  Keyboard Shortcuts</span>"
    )
    header.set_halign(Gtk.Align.START)
    header.set_margin_start(20)
    header.set_margin_top(20)

    logo_paths = [
        "/usr/share/grub/themes/mados/mados-logo.png",
        "/usr/share/pixmaps/mados-logo.png",
        "/mnt/persistence/usr/share/grub/themes/mados/mados-logo.png",
    ]
    logo = Gtk.Image()
    for path in logo_paths:
        if os.path.exists(path):
            logo.set_from_file(path)
            break
    logo.set_pixel_size(64)
    logo.set_margin_end(10)
    logo.set_margin_top(10)

    header_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
    header_box.set_halign(Gtk.Align.FILL)
    header_box.append(header)

    corner = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
    corner.set_halign(Gtk.Align.END)
    corner.set_hexpand(True)
    corner.append(logo)
    header_box.append(corner)

    def build_content(num_cols=1):
        cols = []
        for _ in range(num_cols):
            col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
            col.set_halign(Gtk.Align.FILL)
            cols.append(col)

        for i, (category, items) in enumerate(help_data):
            target_col = cols[i % num_cols]

            cat_label = Gtk.Label()
            cat_label.set_markup(f"<span weight='bold' color='#BF616A'>{category}</span>")
            cat_label.set_halign(Gtk.Align.START)
            cat_label.set_margin_start(20)
            cat_label.set_margin_top(12)
            target_col.append(cat_label)

            for key, desc in items:
                row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
                row.set_margin_start(20)
                row.set_margin_top(4)

                key_label = Gtk.Label()
                key_label.set_markup(f"<span color='#A3BE8C' weight='bold'>{key:18}</span>")
                key_label.set_halign(Gtk.Align.START)
                key_label.set_width_chars(18)
                key_label.add_css_class("key-label")

                desc_label = Gtk.Label()
                desc_label.set_text(desc)
                desc_label.set_halign(Gtk.Align.START)

                row.append(key_label)
                row.append(desc_label)
                target_col.append(row)

        if num_cols == 1:
            return cols[0]
        else:
            cols_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=20)
            cols_box.set_halign(Gtk.Align.FILL)
            for col in cols:
                cols_box.append(col)
            return cols_box

    content_box = build_content(1)

    container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    container.set_halign(Gtk.Align.FILL)
    container.append(header_box)
    container.append(content_box)

    content_ref = [content_box]

    def update_layout():
        width = window.get_width()
        if width >= COLUMN_THRESHOLD_3:
            num_cols = 3
        elif width >= COLUMN_THRESHOLD_2:
            num_cols = 2
        else:
            num_cols = 1
        old_content = content_ref[0]
        container.remove(old_content)
        new_content = build_content(num_cols)
        content_ref[0] = new_content
        container.append(new_content)
        return True

    scrolled = Gtk.ScrolledWindow()
    scrolled.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
    scrolled.set_vexpand(True)
    scrolled.set_hexpand(True)
    scrolled.set_child(container)

    window.set_child(scrolled)

    GLib.timeout_add(500, update_layout)

    return window


if __name__ == "__main__":
    loop = GLib.MainLoop()

    def on_close(window):
        GLib.idle_add(loop.quit)
        return False

    win = create_help_window()
    win.connect("close-request", on_close)
    win.present()
    loop.run()
