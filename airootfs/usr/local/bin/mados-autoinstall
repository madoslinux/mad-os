#!/usr/bin/env bash
# mados-autoinstall - Automatic post-installation hardware configuration
# Called by the installer after system installation completes
# Handles driver installation, DE selection, and initial setup

set -euo pipefail

log() {
    echo "[mados-autoinstall] $1"
}

error() {
    echo "[mados-autoinstall] ERROR: $1" >&2
}

run_as_root() {
    if [[ "$(id -u)" -eq 0 ]]; then
        "$@"
    elif command -v sudo &>/dev/null; then
        sudo "$@"
    else
        return 1
    fi
}

detect_and_configure_gpu() {
    log "Detecting GPU hardware..."

    if command -v mados-chwd &>/dev/null; then
        log "Running mados-chwd --autoconfigure..."
        if mados-chwd --autoconfigure; then
            log "GPU drivers configured successfully"
        else
            error "mados-chwd failed to configure GPU drivers"
        fi
    else
        log "mados-chwd not found, using fallback detection"

        local gpu_type
        gpu_type=$(mados-gpu-detect 2>/dev/null || echo "unknown")

        log "Detected GPU type: $gpu_type"

        case "$gpu_type" in
            nvidia)
                log "NVIDIA GPU detected - installing nvidia-open driver..."
                if command -v pacman &>/dev/null; then
                    run_as_root pacman -S --noconfirm nvidia-open-dkms nvidia-settings 2>/dev/null || true
                fi
                ;;
            amdgpu)
                log "AMD GPU detected - drivers should be included in kernel"
                ;;
            intel)
                log "Intel GPU detected - drivers should be included in kernel"
                ;;
            *)
                log "Unknown GPU or virtual environment"
                ;;
        esac
    fi
}

configure_btrfs_snapshots() {
    local target_dir="${1:-/}"

    if [[ ! -d "${target_dir}/boot" ]]; then
        log "Not configuring Btrfs snapshots (not installed at ${target_dir})"
        return 0
    fi

    log "Checking for Btrfs filesystem..."

    if findmnt -n -o FSTYPE "${target_dir}" | grep -q btrfs; then
        log "Btrfs detected - configuring snapper..."

        if command -v snapper &>/dev/null; then
            if [[ ! -f "${target_dir}/etc/snapper/configs/root" ]]; then
                log "Creating snapper configuration..."
                run_as_root snapper -c root create-config "${target_dir}" 2>/dev/null || true
            fi

            log "Enabling and starting snapper timer..."
            run_as_root systemctl --now enable snapper-timer.timer 2>/dev/null || true
        else
            log "snapper not installed, skipping Btrfs snapshot configuration"
        fi
    else
        log "Not a Btrfs filesystem, skipping snapshot configuration"
    fi
}

enable_services() {
    log "Enabling system services..."

    local services=(
        "mados-snapper.timer"
        "mados-hw-quirks.service"
        "bluetooth.service"
        "NetworkManager.service"
        "firewalld.service"
        "fail2ban.service"
        "usbguard.service"
    )

    for svc in "${services[@]}"; do
        if systemctl list-unit-files "$svc" &>/dev/null; then
            log "Enabling $svc..."
            run_as_root systemctl enable "$svc" 2>/dev/null || true
        fi
    done
}

set_timezone() {
    if command -v mados-timezone-detect &>/dev/null; then
        log "Detecting timezone..."
        if mados-timezone-detect --install 2>/dev/null; then
            log "Timezone configured"
        fi
    fi
}

main() {
    local target_dir="${1:-/}"

    log "Starting post-installation configuration..."
    log "Target installation: ${target_dir}"

    detect_and_configure_gpu

    configure_btrfs_snapshots "${target_dir}"

    set_timezone

    enable_services

    log "Post-installation configuration complete"
}

main "$@"
