#!/usr/bin/env bash
# madOS OTA Update System
# Check for and apply system updates from GitHub Releases
set -e

SCRIPT_NAME="$(basename "$0")"
VERSION_FILE="/etc/mados/version"
CONFIG_FILE="/etc/mados/update.conf"
LOG_FILE="/var/log/mados-update.log"
CACHE_DIR="/var/cache/mados-updates"

# madOS GitHub repository
GITHUB_REPO="madkoding/mad-os"
GITHUB_API="https://api.github.com/repos/${GITHUB_REPO}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ═══════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

info() {
    echo -e "${BLUE}[INFO]${NC} $*"
    log "INFO: $*"
}

success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
    log "SUCCESS: $*"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
    log "WARN: $*"
}

error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
    log "ERROR: $*"
}

# ═══════════════════════════════════════════════════════════════════════════
# Configuration
# ═══════════════════════════════════════════════════════════════════════════

load_config() {
    # Default values
    UPDATE_CHANNEL="${UPDATE_CHANNEL:-stable}"  # stable or beta
    AUTO_DOWNLOAD="${AUTO_DOWNLOAD:-false}"
    DELTA_UPDATES="${DELTA_UPDATES:-true}"
    NOTIFICATION_ENABLED="${NOTIFICATION_ENABLED:-true}"
    
    # Load from config file if exists
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE"
    fi
}

save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" <<EOF
# madOS Update Configuration
# Generated by mados-update

UPDATE_CHANNEL="${UPDATE_CHANNEL}"
AUTO_DOWNLOAD="${AUTO_DOWNLOAD}"
DELTA_UPDATES="${DELTA_UPDATES}"
NOTIFICATION_ENABLED="${NOTIFICATION_ENABLED}"
EOF
    log "Configuration saved to $CONFIG_FILE"
}

# ═══════════════════════════════════════════════════════════════════════════
# Version Detection
# ═══════════════════════════════════════════════════════════════════════════

get_current_version() {
    if [ -f "$VERSION_FILE" ]; then
        cat "$VERSION_FILE"
    else
        echo "unknown"
    fi
}

get_latest_version() {
    local tag
    local url
    
    if [ "$UPDATE_CHANNEL" = "beta" ]; then
        # Get latest release including pre-releases
        url="${GITHUB_API}/releases"
        tag=$(curl -s "$url" | jq -r '.[0].tag_name' 2>/dev/null)
    else
        # Get latest stable release
        url="${GITHUB_API}/releases/latest"
        tag=$(curl -s "$url" | jq -r '.tag_name' 2>/dev/null)
    fi
    
    if [ -z "$tag" ] || [ "$tag" = "null" ]; then
        error "Failed to fetch latest version from GitHub"
        return 1
    fi
    
    echo "$tag"
}

compare_versions() {
    local current="$1"
    local latest="$2"
    
    # Remove 'v' prefix if present
    current="${current#v}"
    latest="${latest#v}"
    
    if [ "$current" = "$latest" ]; then
        echo "same"
    elif [ "$(printf '%s\n' "$current" "$latest" | sort -V | head -n1)" = "$latest" ]; then
        echo "older"
    else
        echo "newer"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# Update Check
# ═══════════════════════════════════════════════════════════════════════════

check_for_updates() {
    local current_version
    local latest_version
    local version_status
    
    info "Checking for updates (${UPDATE_CHANNEL} channel)..."
    
    current_version=$(get_current_version)
    latest_version=$(get_latest_version) || return 1
    
    version_status=$(compare_versions "$current_version" "$latest_version")
    
    info "Current version: $current_version"
    info "Latest version: $latest_version"
    
    case "$version_status" in
        same)
            success "System is up to date"
            return 0
            ;;
        older)
            warn "New version available: $latest_version"
            show_release_info "$latest_version"
            return 2  # Update available
            ;;
        newer)
            warn "Current version ($current_version) is newer than latest release ($latest_version)"
            warn "You may be on a development branch"
            return 0
            ;;
    esac
}

show_release_info() {
    local version="$1"
    local url="${GITHUB_API}/releases/tags/$version"
    local response
    
    response=$(curl -s "$url")
    
    local name published_at body download_url
    
    name=$(echo "$response" | jq -r '.name // "Unknown"')
    published_at=$(echo "$response" | jq -r '.published_at // "Unknown"')
    body=$(echo "$response" | jq -r '.body // "No changelog available"')
    
    echo ""
    info "Release Information:"
    echo "  Name: $name"
    echo "  Published: $published_at"
    echo ""
    echo "Changelog:"
    echo "$body" | head -20
    echo "..."
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════════
# Download Update
# ═══════════════════════════════════════════════════════════════════════════

download_update() {
    local version="$1"
    local iso_url sha_url iso_name
    
    mkdir -p "$CACHE_DIR"
    
    info "Downloading madOS $version..."
    
    # Get download URL from release
    local url="${GITHUB_API}/releases/tags/$version"
    local response
    response=$(curl -s "$url")
    
    # Find ISO asset URL
    iso_url=$(echo "$response" | jq -r '.assets[] | select(.name | endswith(".iso")) | .browser_download_url' | head -1)
    sha_url=$(echo "$response" | jq -r '.assets[] | select(.name | endswith("SHA256SUMS")) | .browser_download_url' | head -1)
    
    if [ -z "$iso_url" ]; then
        error "ISO file not found in release"
        return 1
    fi
    
    iso_name=$(basename "$iso_url")
    
    info "Downloading ISO: $iso_name"
    
    # Download with progress
    curl -L# -o "$CACHE_DIR/$iso_name" "$iso_url"
    
    # Download SHA256SUMS
    if [ -n "$sha_url" ]; then
        info "Downloading SHA256SUMS..."
        curl -sL -o "$CACHE_DIR/SHA256SUMS" "$sha_url"
        
        # Verify checksum
        info "Verifying checksum..."
        cd "$CACHE_DIR"
        if sha256sum -c SHA256SUMS 2>/dev/null | grep -q "OK"; then
            success "Checksum verified"
        else
            warn "Checksum verification failed or not applicable"
        fi
        cd - > /dev/null
    fi
    
    success "Download complete: $CACHE_DIR/$iso_name"
    
    # Save version info
    echo "$version" > "$CACHE_DIR/downloaded_version"
    
    return 0
}

# ═══════════════════════════════════════════════════════════════════════════
# Delta Updates (Optional - for future implementation)
# ═══════════════════════════════════════════════════════════════════════════

check_delta_support() {
    # Check if zstd and delta tools are available
    if command -v zstd &>/dev/null && command -v xdelta3 &>/dev/null; then
        return 0
    else
        return 1
    fi
}

apply_delta_update() {
    warn "Delta updates not yet implemented"
    warn "Full ISO download will be used instead"
    return 1
}

# ═══════════════════════════════════════════════════════════════════════════
# Notification
# ═══════════════════════════════════════════════════════════════════════════

send_notification() {
    local title="$1"
    local message="$2"
    local urgency="${3:-normal}"  # low, normal, critical
    
    if [ "$NOTIFICATION_ENABLED" != "true" ]; then
        return 0
    fi
    
    # Try different notification methods
    
    # Method 1: notify-send (freedesktop)
    if command -v notify-send &>/dev/null; then
        notify-send -u "$urgency" -a "madOS Update" "$title" "$message"
        return 0
    fi
    
    # Method 2: Waybar custom module (write to file)
    if [ -d "$HOME/.config/waybar" ]; then
        mkdir -p "$HOME/.cache/mados"
        echo "{\"text\": \"🔄\", \"tooltip\": \"$title: $message\"}" > "$HOME/.cache/mados/update_notification"
    fi
    
    # Method 3: Log to journal
    logger -t "mados-update" -p "user.$urgency" "$title: $message"
}

# ═══════════════════════════════════════════════════════════════════════════
# Installation Guide
# ═══════════════════════════════════════════════════════════════════════════

show_install_guide() {
    echo ""
    info "To install the downloaded update:"
    echo ""
    echo "1. Boot from the downloaded ISO in Ventoy (persistence mode)"
    echo "2. Your data will be preserved automatically"
    echo "3. Or perform a fresh install with backup/restore"
    echo ""
    echo "Downloaded ISO location: $CACHE_DIR/"
    echo ""
    warn "Note: madOS uses a rolling update model for packages."
    warn "This OTA system provides full ISO updates for major version upgrades."
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════════
# Main Commands
# ═══════════════════════════════════════════════════════════════════════════

cmd_check() {
    load_config
    check_for_updates
}

cmd_download() {
    load_config
    
    local version
    version=$(get_latest_version) || exit 1
    
    download_update "$version"
}

cmd_update() {
    load_config
    
    info "Starting OTA update process..."
    
    # Check for updates
    if ! check_for_updates; then
        local exit_code=$?
        if [ $exit_code -eq 2 ]; then
            # Update available
            local latest
            latest=$(get_latest_version) || exit 1
            
            # Download
            if download_update "$latest"; then
                success "Update downloaded successfully"
                send_notification "Update Ready" "madOS $latest has been downloaded" "normal"
                show_install_guide
            else
                error "Failed to download update"
                exit 1
            fi
        else
            exit 0
        fi
    fi
}

cmd_configure() {
    load_config
    
    echo "madOS Update Configuration"
    echo "========================="
    echo ""
    echo "Current settings:"
    echo "  UPDATE_CHANNEL=$UPDATE_CHANNEL"
    echo "  AUTO_DOWNLOAD=$AUTO_DOWNLOAD"
    echo "  DELTA_UPDATES=$DELTA_UPDATES"
    echo "  NOTIFICATION_ENABLED=$NOTIFICATION_ENABLED"
    echo ""
    
    # Interactive configuration
    read -rp "Update channel (stable/beta) [$UPDATE_CHANNEL]: " channel_input
    [ -n "$channel_input" ] && UPDATE_CHANNEL="$channel_input"
    
    read -rp "Auto-download updates (true/false) [$AUTO_DOWNLOAD]: " download_input
    [ -n "$download_input" ] && AUTO_DOWNLOAD="$download_input"
    
    read -rp "Enable notifications (true/false) [$NOTIFICATION_ENABLED]: " notify_input
    [ -n "$notify_input" ] && NOTIFICATION_ENABLED="$notify_input"
    
    save_config
    
    success "Configuration saved"
}

cmd_status() {
    load_config
    
    local current_version
    current_version=$(get_current_version)
    
    echo "madOS Update Status"
    echo "==================="
    echo ""
    echo "Current Version: $current_version"
    echo "Update Channel: $UPDATE_CHANNEL"
    echo "Auto-download: $AUTO_DOWNLOAD"
    echo "Notifications: $NOTIFICATION_ENABLED"
    echo ""
    
    # Check for cached download
    if [ -f "$CACHE_DIR/downloaded_version" ]; then
        local downloaded
        downloaded=$(cat "$CACHE_DIR/downloaded_version")
        echo "Downloaded Update: $downloaded"
        echo "Location: $CACHE_DIR/"
    fi
}

cmd_clean() {
    if [ -d "$CACHE_DIR" ]; then
        info "Cleaning update cache..."
        rm -rf "$CACHE_DIR"/*
        success "Cache cleaned"
    else
        info "Cache is already empty"
    fi
}

show_help() {
    echo "madOS OTA Update System"
    echo ""
    echo "Usage: $SCRIPT_NAME <command>"
    echo ""
    echo "Commands:"
    echo "  check      Check for available updates"
    echo "  download   Download latest update"
    echo "  update     Check and download if available"
    echo "  configure  Interactive configuration"
    echo "  status     Show current status"
    echo "  clean      Clean update cache"
    echo "  help       Show this help message"
    echo ""
    echo "Examples:"
    echo "  $SCRIPT_NAME check"
    echo "  $SCRIPT_NAME update"
    echo "  $SCRIPT_NAME configure"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════════
# Main Entry Point
# ═══════════════════════════════════════════════════════════════════════════

main() {
    # Ensure log directory exists
    mkdir -p "$(dirname "$LOG_FILE")"
    
    local command="${1:-help}"
    
    case "$command" in
        check)
            cmd_check
            ;;
        download)
            cmd_download
            ;;
        update)
            cmd_update
            ;;
        configure|config)
            cmd_configure
            ;;
        status)
            cmd_status
            ;;
        clean)
            cmd_clean
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            error "Unknown command: $command"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
