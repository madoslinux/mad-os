#!/usr/bin/env bash
# Wrapper for gufw - called via sudo from .desktop, already running as root
# Just pass Wayland environment and exec directly

if [ -n "$WAYLAND_DISPLAY" ]; then
    export WAYLAND_DISPLAY="$WAYLAND_DISPLAY"
    export XDG_CURRENT_DESKTOP=Hyprland
    export XDG_SESSION_TYPE=wayland
    export GDK_BACKEND=wayland
fi

exec /usr/bin/python3 /usr/lib/python3.14/site-packages/gufw/gufw.py "$@"