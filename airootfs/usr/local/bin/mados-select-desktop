#!/usr/bin/env bash
# mados-select-desktop - Desktop selector for madOS-lite

set -euo pipefail

SCRIPT_NAME="$(basename "$0")"
DESKTOP_CONFIGS_DIR="/etc/skel/.config"
SELECTED_DESKTOP=""

usage() {
    cat << EOF
${SCRIPT_NAME} - Select desktop environment or window manager

USAGE:
    ${SCRIPT_NAME} [OPTIONS]

OPTIONS:
    list                List available desktop environments
    set DESKTOP        Set the desktop environment (requires restart)
    current             Show current desktop environment
    help                Show this help message

AVAILABLE DESKTOPS:
    sway        - Sway compositor (X11 backend in madOS-lite)

EXAMPLES:
    ${SCRIPT_NAME} list
    ${SCRIPT_NAME} set sway
    ${SCRIPT_NAME} current

EOF
}

list_desktops() {
    echo "Available Desktop Environments:"
    echo "================================"
    echo ""

    local desktops=(
        "sway:Sway compositor - X11 backend (no DRM required)"
    )

    for entry in "${desktops[@]}"; do
        local id="${entry%%:*}"
        local desc="${entry#*:}"
        echo "  $id"
        echo "    $desc"
        echo ""
    done

    echo "To set a desktop: ${SCRIPT_NAME} set <desktop>"
}

check_desktop_available() {
    local desktop="$1"

    case "$desktop" in
        sway)
            command -v sway &>/dev/null
            ;;
        *)
            return 1
            ;;
    esac
}

set_desktop() {
    local desktop="$1"

    if ! check_desktop_available "$desktop"; then
        echo "ERROR: Desktop '$desktop' is not installed or not available." >&2
        return 1
    fi

    echo "Setting default desktop to: $desktop"

    local desktop_file="${DESKTOP_CONFIGS_DIR}/desktop-selected"

    mkdir -p "$(dirname "$desktop_file")"
    echo "$desktop" > "$desktop_file"

    echo "✓ Default desktop set to '$desktop'"
    echo ""
    echo "To apply changes:"
    echo "  - Log out and log back in"
    echo "  - Or restart your session"
}

get_current_desktop() {
    if [[ -f "${DESKTOP_CONFIGS_DIR}/desktop-selected" ]]; then
        cat "${DESKTOP_CONFIGS_DIR}/desktop-selected"
    elif [[ -n "$XDG_CURRENT_DESKTOP" ]]; then
        echo "$XDG_CURRENT_DESKTOP"
    elif [[ -n "$DESKTOP_SESSION" ]]; then
        echo "$DESKTOP_SESSION"
    else
        echo "unknown"
    fi
}

main() {
    if [[ $# -eq 0 ]]; then
        usage
        return 1
    fi

    local command="$1"
    shift || true

    case "$command" in
        list)
            list_desktops
            ;;
        set)
            if [[ -z "${1:-}" ]]; then
                echo "ERROR: Desktop name required" >&2
                echo "Usage: ${SCRIPT_NAME} set <desktop>" >&2
                return 1
            fi
            set_desktop "$1"
            ;;
        current)
            echo "Current desktop: $(get_current_desktop)"
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            echo "ERROR: Unknown command: $command" >&2
            usage
            return 1
            ;;
    esac
}

main "$@"
