#!/bin/bash
set -euo pipefail

export XDG_CURRENT_DESKTOP=sway
export XDG_SESSION_TYPE=x11
export MOZ_ENABLE_WAYLAND=0

export WLR_BACKENDS=x11
export WLR_RENDERER=pixman
export WLR_NO_HARDWARE_CURSORS=1
export LIBGL_ALWAYS_SOFTWARE=1
export MESA_GL_VERSION_OVERRIDE=3.3
export GSK_RENDERER=cairo
export CHROMIUM_FLAGS="${CHROMIUM_FLAGS:-} --disable-gpu"
export __GLX_VENDOR_LIBRARY_NAME=mesa
export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/50_mesa.json

if ! command -v xinit >/dev/null 2>&1; then
    logger -p user.err -t mados-sway "xinit not found; cannot run sway X11 fallback"
    echo "xinit not found; cannot start Sway X11 fallback"
    exit 1
fi

if ! command -v Xorg >/dev/null 2>&1; then
    logger -p user.err -t mados-sway "Xorg not found; cannot run sway X11 fallback"
    echo "Xorg not found; cannot start Sway X11 fallback"
    exit 1
fi

if ! command -v sway >/dev/null 2>&1; then
    logger -p user.err -t mados-sway "sway not found; cannot run X11 fallback"
    echo "sway not found; cannot start Sway X11 fallback"
    exit 1
fi

TMP_DIR="${XDG_RUNTIME_DIR:-/tmp}"
XINITRC="$(mktemp "${TMP_DIR}/mados-sway-x11.XXXXXX")"
XORG_CONF_DIR="$(mktemp -d "${TMP_DIR}/mados-sway-xorg.XXXXXX")"
XORG_CONF="${XORG_CONF_DIR}/xorg.conf"
cleanup() {
    rm -f "$XINITRC"
    rm -rf "$XORG_CONF_DIR"
}
trap cleanup EXIT

cat > "$XINITRC" << 'XINITEOF'
#!/bin/sh
export XDG_CURRENT_DESKTOP=sway
export XDG_SESSION_TYPE=x11
export MOZ_ENABLE_WAYLAND=0
export WLR_BACKENDS=x11
export WLR_RENDERER=pixman
export WLR_NO_HARDWARE_CURSORS=1
export LIBGL_ALWAYS_SOFTWARE=1
export MESA_GL_VERSION_OVERRIDE=3.3
export GSK_RENDERER=cairo
export CHROMIUM_FLAGS="${CHROMIUM_FLAGS:-} --disable-gpu"

get_edid_native_resolution() {
    local resolution=""
    local edid_file=""
    local display=""

    for conn in /sys/class/drm/card*-*; do
        [ -d "$conn" ] || continue
        status=$(cat "$conn/status" 2>/dev/null || echo "unknown")
        if [ "$status" = "connected" ]; then
            display=$(basename "$conn")
            edid_file="$conn/edid"
            break
        fi
    done

    [ -z "$display" ] && return 1
    [ ! -s "$edid_file" ] && return 1

    if command -v edid-decode >/dev/null 2>&1; then
        local modeline
        modeline=$(edid-decode "$edid_file" 2>/dev/null | grep -m1 "Preferred mode" || true)
        if [ -n "$modeline" ]; then
            resolution=$(echo "$modeline" | grep -oP '\d+x\d+' | head -1 || true)
        fi
    fi

    if [ -z "$resolution" ] && [ -s "$edid_file" ]; then
        local hex_edid
        hex_edid=$(xxd -p "$edid_file" 2>/dev/null | tr -d '\n' || true)
        if [ -n "$hex_edid" ]; then
            local width height
            width=$(printf '%d' "0x${hex_edid:168:4}" 2>/dev/null || true)
            height=$(printf '%d' "0x${hex_edid:172:4}" 2>/dev/null || true)
            if [ -n "$width" ] && [ -n "$height" ] && [ "$width" -gt 0 ] && [ "$height" -gt 0 ]; then
                resolution="${width}x${height}"
            fi
        fi
    fi

    if [ -n "$resolution" ]; then
        echo "$resolution"
        return 0
    fi
    return 1
}

ROOT_MODE=""
if command -v xrandr >/dev/null 2>&1; then
    if ! get_edid_native_resolution >/dev/null 2>&1; then
        ROOT_MODE="$(xrandr --current 2>/dev/null | awk 'match($0, /current[[:space:]]+([0-9]+)[[:space:]]+x[[:space:]]+([0-9]+)/, m) { print m[1] "x" m[2]; exit }')"
    else
        ROOT_MODE="$(get_edid_native_resolution)"
    fi
fi

if [ -n "$ROOT_MODE" ] && [ -f "$HOME/.config/sway/config" ]; then
    SWAY_TMP_CONFIG="${XDG_RUNTIME_DIR:-/tmp}/mados-sway-x11-config.$$"
    cp "$HOME/.config/sway/config" "$SWAY_TMP_CONFIG"
    {
        printf "\n# mados x11 fallback dynamic output mode\n"
        printf "output * mode %s\n" "$ROOT_MODE"
        printf "output * pos 0 0\n"
        printf "output * scale 1\n"
    } >> "$SWAY_TMP_CONFIG"
    logger -p user.info -t mados-sway "X11 fallback using native mode ${ROOT_MODE}"
    exec sway -c "$SWAY_TMP_CONFIG"
fi

exec sway
XINITEOF
chmod +x "$XINITRC"

write_xorg_conf() {
    local driver="$1"
    cat > "$XORG_CONF" << EOF
Section "Monitor"
    Identifier "FallbackMonitor"
EndSection

Section "Device"
    Identifier "FallbackGPU"
    Driver "${driver}"
EndSection

Section "Screen"
    Identifier "FallbackScreen"
    Device "FallbackGPU"
    Monitor "FallbackMonitor"
EndSection

Section "ServerLayout"
    Identifier "FallbackLayout"
    Screen "FallbackScreen"
EndSection
EOF
}

driver_module_path() {
    local driver="$1"
    echo "/usr/lib/xorg/modules/drivers/${driver}_drv.so"
}

run_with_driver() {
    local driver="$1"
    local module_path
    module_path=$(driver_module_path "$driver")

    if [ ! -f "$module_path" ]; then
        logger -p user.warning -t mados-sway "Skipping X11 fallback driver ${driver}: module not found (${module_path})"
        return 1
    fi

    write_xorg_conf "$driver"
    logger -p user.warning -t mados-sway "Trying X11 fallback with Xorg driver: ${driver}"
    (
        cd "$XORG_CONF_DIR"
        xinit "$XINITRC" -- /usr/bin/Xorg :0 -nolisten tcp -config xorg.conf -extension GLX -extension DRI2 -extension DRI3
    )
}

logger -p user.warning -t mados-sway "No DRM card found, launching sway via X11 fallback"
echo "No DRM card found, launching Sway with X11 fallback"

if run_with_driver "vesa"; then
    exit 0
fi

logger -p user.warning -t mados-sway "VESA fallback failed, retrying with fbdev"
if run_with_driver "fbdev"; then
    exit 0
fi

logger -p user.warning -t mados-sway "fbdev fallback failed, retrying with dummy"
if run_with_driver "dummy"; then
    exit 0
fi

logger -p user.err -t mados-sway "X11 fallback failed (vesa/fbdev/dummy). Check /var/log/Xorg.0.log"
echo "X11 fallback failed (vesa/fbdev/dummy). Check /var/log/Xorg.0.log"
exit 1
