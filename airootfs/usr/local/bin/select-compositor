#!/bin/bash
# select-compositor - Selects compositor for madOS-lite
# madOS-lite always uses Sway as primary compositor (optimized for software rendering)
# i3-wm is available as fallback for when Sway is not available

select_compositor() {
    # madOS-lite: always use sway for Wayland compositor
    # Legacy hardware detection is handled by sway-session directly
    if command -v sway >/dev/null 2>&1; then
        logger -p user.info -t mados-compositor "madOS-lite: selecting sway"
        echo "sway"
    else
        # Fallback to i3-wm if sway is not available
        logger -p user.warning -t mados-compositor "sway not found - falling back to i3"
        echo "i3"
    fi
}

# If sourced, export function. If executed, print result.
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    select_compositor
fi
