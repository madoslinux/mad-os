#!/usr/bin/env bash
# select-compositor - madOS compositor selector
# Returns "hyprland" when available.
# If Hyprland is missing, still returns "hyprland" to keep
# session startup deterministic in Wayland-only builds.

select_compositor() {
    if command -v Hyprland >/dev/null 2>&1; then
        logger -p user.info -t mados-compositor "madOS: selecting hyprland"
        echo "hyprland"
    else
        logger -p user.warning -t mados-compositor "Hyprland not found - returning hyprland for deterministic startup"
        echo "hyprland"
    fi
}

# If sourced, export function. If executed, print result.
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    select_compositor
fi
