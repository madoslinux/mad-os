#!/usr/bin/env python3

import gi
import os
import subprocess

gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk

lang = os.environ.get("LANG", "C").split(".")[0]
if "-" in lang:
    lang = lang.split("-")[0]

translations = {
    "es": {"logout": "Cerrar sesión", "restart": "Reiniciar", "poweroff": "Apagar"},
    "en": {"logout": "Logout", "restart": "Restart", "poweroff": "Power Off"},
    "fr": {"logout": "Déconnexion", "restart": "Redémarrer", "poweroff": "Éteindre"},
    "pt": {"logout": "Terminar sessão", "restart": "Reiniciar", "poweroff": "Desligar"},
    "it": {"logout": "Disconnetti", "restart": "Riavvia", "poweroff": "Spegni"},
    "de": {"logout": "Abmelden", "restart": "Neu starten", "poweroff": "Herunterfahren"},
    "zh": {"logout": "注销", "restart": "重启", "poweroff": "关机"},
    "ja": {"logout": "ログアウト", "restart": "再起動", "poweroff": "電源オフ"},
    "ko": {"logout": "ログアウト", "restart": "再起動", "poweroff": "電源オフ"},
}

t = translations.get(lang, translations["en"])

css_provider = """
* { font-family: 'Michroma', 'Noto Sans CJK SC', 'Noto Sans CJK JP', 'Noto Sans CJK KR', sans-serif; font-size: 12px; }
window { background: rgba(46, 52, 64, 0.85); border-radius: 12px; }
.btn { background: #3B4252; border: 2px solid #88C0D0; border-radius: 8px; padding: 8px; }
.btn:hover { background: #434C5E; border-color: #81A1C1; }
.btn-icon { font-size: 28px; }
.btn-label { font-weight: bold; color: #ECEFF4; }
.btn-desc { color: #D8DEE9; font-size: 11px; }
"""


def create_power_window():
    window = Gtk.Window()
    window.set_title("Power Menu")
    window.set_default_size(400, 180)
    window.set_resizable(False)
    window.set_decorated(False)
    window.set_transient_for(None)
    window.connect("close_request", lambda w: w.destroy())

    controller = Gtk.EventControllerKey()
    controller.connect("key-pressed", on_key_pressed, window)
    window.add_controller(controller)

    css = Gtk.CssProvider()
    css.load_from_string(css_provider)
    display = Gdk.Display.get_default()
    Gtk.StyleContext.add_provider_for_display(display, css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    main_box.set_margin_top(10)
    main_box.set_margin_bottom(10)
    main_box.set_margin_start(10)
    main_box.set_margin_end(10)

    title = Gtk.Label()
    title.set_markup("<span size='large' weight='bold' color='#88C0D0'>⏻  Power Menu</span>")
    title.set_margin_bottom(10)
    main_box.append(title)

    buttons_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=15)
    buttons_box.set_homogeneous(True)

    logout_btn = create_button("⎋", t["logout"], "#BF616A", "logout")
    restart_btn = create_button("⟳", t["restart"], "#E5C07B", "restart")
    poweroff_btn = create_button("⏻", t["poweroff"], "#61AFEF", "poweroff")

    buttons_box.append(logout_btn)
    buttons_box.append(restart_btn)
    buttons_box.append(poweroff_btn)

    main_box.append(buttons_box)
    window.set_child(main_box)

    return window


def create_button(icon, label, color, action):
    btn = Gtk.Button()
    btn.set_css_name("btn")
    btn.add_css_class("btn")
    btn.set_size_request(90, 90)

    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
    box.set_halign(Gtk.Align.CENTER)
    box.set_valign(Gtk.Align.CENTER)

    icon_label = Gtk.Label()
    icon_label.set_markup(f"<span color='{color}' size='30000'>{icon}</span>")
    box.append(icon_label)

    text_label = Gtk.Label()
    text_label.set_markup(f"<span color='{color}' weight='bold'>{label}</span>")
    box.append(text_label)

    btn.set_child(box)
    btn.connect("clicked", on_button_clicked, action)

    return btn


def get_window_manager():
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        return "hyprland"
    elif os.environ.get("SWAYSOCK"):
        return "sway"
    elif os.environ.get("WAYLAND_DISPLAY"):
        return "niri"
    elif os.environ.get("DESKTOP_SESSION"):
        session = os.environ["DESKTOP_SESSION"].lower()
        if "sway" in session:
            return "sway"
        elif "hypr" in session:
            return "hyprland"
        elif "niri" in session:
            return "niri"
    return None


def logout():
    wm = get_window_manager()
    if wm == "hyprland":
        subprocess.run(["hyprctl", "dispatch", "exit"])
    elif wm == "sway":
        subprocess.run(["swaymsg", "exit"])
    elif wm == "niri":
        subprocess.run(["niri", "msg", "exit"])
    else:
        subprocess.run(["loginctl", "terminate-user", os.environ.get("USER", "")])


def on_button_clicked(btn, action):
    if action == "logout":
        logout()
    elif action == "restart":
        subprocess.run(["systemctl", "reboot"])
    elif action == "poweroff":
        subprocess.run(["systemctl", "poweroff"])


def on_key_pressed(controller, keyval, keycode, state, window):
    if keyval == Gdk.KEY_Escape:
        window.close()
        return True
    return False


if __name__ == "__main__":
    win = create_power_window()
    win.present()
    Gtk.main()
