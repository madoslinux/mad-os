#!/bin/bash
log() { echo "$1" | systemd-cat -t cage-greeter -p "${2:-info}" 2>/dev/null; }
LOG_TAG="cage-greeter"

command -v cage >/dev/null 2>&1 || { log "cage not found" "err"; sleep 2; exit 1; }
command -v regreet >/dev/null 2>&1 || { log "regreet not found" "err"; sleep 2; exit 1; }

[ -z "$XDG_RUNTIME_DIR" ] && export XDG_RUNTIME_DIR="/run/user/$(id -u)" && mkdir -p "$XDG_RUNTIME_DIR" 2>/dev/null
export LIBSEAT_BACKEND=logind

# Detect early to avoid retry flicker
USE_SOFTWARE=0
if systemd-detect-virt --oracle --quiet 2>/dev/null; then
    USE_SOFTWARE=1
    export MADOS_DEFAULT_SESSION="sway"
    log "VirtualBox detected"
elif systemd-detect-virt --vm --quiet 2>/dev/null; then
    USE_SOFTWARE=1
    export MADOS_DEFAULT_SESSION="sway"
    log "VM detected"
else
    export MADOS_DEFAULT_SESSION="hyprland"
    log "Hardware detected"
fi

[ $USE_SOFTWARE -eq 1 ] && export WLR_RENDERER=pixman WLR_NO_HARDWARE_CURSORS=1 LIBGL_ALWAYS_SOFTWARE=1 GSK_RENDERER=cairo
systemd-detect-virt --vm --quiet 2>/dev/null && export WLR_DRM_NO_ATOMIC=1 WLR_DRM_NO_MODIFIERS=1

[ -x /usr/local/bin/setup-greeter-session ] && /usr/local/bin/setup-greeter-session

# Silence all output
exec 0</dev/null 1>/dev/null 2>&1
cage -s -- regreet
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ] && [ $USE_SOFTWARE -eq 0 ]; then
    export WLR_RENDERER=pixman WLR_NO_HARDWARE_CURSORS=1 LIBGL_ALWAYS_SOFTWARE=1 GSK_RENDERER=cairo
    cage -s -- regreet
    EXIT_CODE=$?
fi

[ $EXIT_CODE -ne 0 ] && { log "cage FAILED ($EXIT_CODE)" "err"; sleep 2; }
exit $EXIT_CODE
