#!/usr/bin/env bash
# mados-hyprland-wallpaper - Change wallpaper based on workspace
# Called from waybar hyprland/workspaces module

DB_PATH="${HOME}/.local/share/mados/wallpapers.db"

if [[ -n "${1:-}" ]]; then
    ws="${1}"
else
    ws="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id // empty' 2>/dev/null)" || ws="1"
fi

if [[ -f "$DB_PATH" ]] && command -v sqlite3 >/dev/null 2>&1; then
    read -r wallpaper mode <<< "$(sqlite3 "$DB_PATH" \
        "SELECT w.path, COALESCE(a.mode, 'fill') FROM assignments a JOIN wallpapers w ON a.wallpaper_id=w.id WHERE a.workspace=$ws LIMIT 1;" 2>/dev/null)"
    if [[ -n "$wallpaper" && -f "$wallpaper" ]]; then
        if command -v swww >/dev/null 2>&1 && swww query >/dev/null 2>&1; then
            if swww img "$wallpaper" --transition-type wipe --transition-duration 0.3 2>/dev/null; then
                sleep 0.5
            elif swww img "$wallpaper" 2>/dev/null; then
                sleep 0.5
            fi
        elif command -v swaybg >/dev/null 2>&1; then
            pkill -f "swaybg.*-i" 2>/dev/null || true
            swaybg -i "$wallpaper" -m "$mode" &
        fi
    fi
fi
