#!/usr/bin/env bash
set -euo pipefail

LOG_TAG="mados-auto-session"
COMPOSITOR="sway"

if [ -x /usr/local/bin/select-compositor ]; then
    COMPOSITOR=$(/usr/local/bin/select-compositor 2>/dev/null || echo "sway")
fi

logger -p user.info -t "$LOG_TAG" "Selected compositor: ${COMPOSITOR}"

if [ "$COMPOSITOR" = "hyprland" ]; then
    logger -p user.info -t "$LOG_TAG" "Launching hyprland-session"
    if /usr/local/bin/hyprland-session; then
        exit 0
    fi
    logger -p user.warning -t "$LOG_TAG" "hyprland-session failed, falling back to sway-session"
fi

logger -p user.info -t "$LOG_TAG" "Launching sway-session"
exec /usr/local/bin/sway-session
