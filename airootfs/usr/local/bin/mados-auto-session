#!/bin/bash
set -euo pipefail

LOG_TAG="mados-auto-session"
COMPOSITOR="hyprland"

if [ -x /usr/local/bin/select-compositor ]; then
    COMPOSITOR=$(/usr/local/bin/select-compositor 2>/dev/null || echo "hyprland")
fi

logger -p user.info -t "$LOG_TAG" "Selected compositor: ${COMPOSITOR}"

if [ "$COMPOSITOR" != "hyprland" ]; then
    logger -p user.warning -t "$LOG_TAG" "Unsupported compositor '${COMPOSITOR}' requested in Wayland-only build; forcing hyprland-session"
fi

logger -p user.info -t "$LOG_TAG" "Launching hyprland-session"
exec /usr/local/bin/hyprland-session
