#!/usr/bin/env bash
# mados-rate-mirrors - Rank Arch Linux mirrors by speed
# Uses curl to measure download speed from each mirror

set -euo pipefail

SCRIPT_NAME="$(basename "$0")"
MIRRORLIST="/etc/pacman.d/mirrorlist"
BACKUP="${MIRRORLIST}.bak"
MAX_MIRRORS=10
TIMEOUT=10

usage() {
    cat << EOF
${SCRIPT_NAME} - Rank Arch Linux mirrors by download speed

USAGE:
    ${SCRIPT_NAME} [OPTIONS]

OPTIONS:
    -n, --number NUM     Number of top mirrors to keep (default: ${MAX_MIRRORS})
    -t, --timeout SEC    Timeout per mirror in seconds (default: ${TIMEOUT})
    -b, --backup         Create backup of current mirrorlist
    -h, --help           Show this help message

EXAMPLES:
    ${SCRIPT_NAME}              # Rank and update mirrorlist with top 10
    ${SCRIPT_NAME} -n 20        # Keep top 20 mirrors
    ${SCRIPT_NAME} --backup     # Backup before updating

EOF
}

log() {
    echo "[${SCRIPT_NAME}] $1"
}

error() {
    echo "[${SCRIPT_NAME}] ERROR: $1" >&2
}

check_dependencies() {
    if ! command -v curl &>/dev/null; then
        error "curl is required but not installed"
        return 1
    fi
    if ! command -v grep &>/dev/null; then
        error "grep is required but not installed"
        return 1
    fi
    return 0
}

create_backup() {
    if [[ -f "$BACKUP" ]]; then
        log "Backup already exists at ${BACKUP}"
    else
        log "Creating backup at ${BACKUP}"
        cp "$MIRRORLIST" "$BACKUP"
    fi
}

extract_mirrors() {
    grep -E "^Server" "$MIRRORLIST" 2>/dev/null | sed 's/Server = //' | sed 's/\$repo/\$repo/g' | sed 's/\$arch/\$arch/g'
}

test_mirror_speed() {
    local mirror="$1"
    local url="${mirror}core/os/x86_64/core.db"

    local start_time
    local end_time
    local speed
    local size

    start_time=$(date +%s%N)

    if size=$(curl -sfw "%{size_download}" --connect-timeout "$TIMEOUT" --max-time "$TIMEOUT" -o /dev/null "$url" 2>/dev/null); then
        end_time=$(date +%s%N)
        speed=$(echo "scale=2; $size * 1000000000 / ($end_time - $start_time) / 1024 / 1024" | bc 2>/dev/null || echo "0")
        echo "$speed $mirror"
    else
        echo "0 $mirror"
    fi
}

rank_mirrors() {
    log "Fetching mirror list..."

    local mirrors
    mirrors=$(extract_mirrors)

    if [[ -z "$mirrors" ]]; then
        error "No mirrors found in ${MIRRORLIST}"
        return 1
    fi

    local mirror_count
    mirror_count=$(echo "$mirrors" | wc -l)
    log "Found ${mirror_count} mirrors, testing speeds..."

    local results_file
    results_file=$(mktemp)

    echo "$mirrors" | while read -r mirror; do
        if [[ -n "$mirror" ]]; then
            speed_info=$(test_mirror_speed "$mirror")
            echo "$speed_info" >> "$results_file"
            printf "."
        fi
    done
    echo ""

    log "Sorting mirrors by speed..."

    local sorted_mirrors
    sorted_mirrors=$(sort -rn "$results_file" | head -n "$MAX_MIRRORS")

    rm -f "$results_file"

    log "Top ${MAX_MIRRORS} mirrors:"
    echo "$sorted_mirrors" | while read -r speed mirror; do
        log "  ${speed} MB/s - ${mirror}"
    done

    generate_new_mirrorlist "$sorted_mirrors"
}

generate_new_mirrorlist() {
    local sorted_mirrors="$1"

    log "Generating new mirrorlist..."

    local tmp_mirrorlist
    tmp_mirrorlist=$(mktemp)

    cat > "$tmp_mirrorlist" << 'HEADER'
# madOS Mirrorlist
# Generated by mados-rate-mirrors
# By speed (fastest first)

HEADER

    echo "$sorted_mirrors" | while read -r speed mirror; do
        echo "Server = ${mirror}" >> "$tmp_mirrorlist"
    done

    if diff -q "$tmp_mirrorlist" "$MIRRORLIST" &>/dev/null; then
        log "Mirrorlist unchanged"
        rm -f "$tmp_mirrorlist"
    else
        log "Replacing ${MIRRORLIST} with optimized mirrorlist"
        mv "$tmp_mirrorlist" "$MIRRORLIST"
        chmod 644 "$MIRRORLIST"
        log "Done! Run 'sudo pacman -Syu' to update."
    fi
}

main() {
    local do_backup=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n|--number)
                MAX_MIRRORS="${2:-10}"
                shift 2
                ;;
            -t|--timeout)
                TIMEOUT="${2:-10}"
                shift 2
                ;;
            -b|--backup)
                do_backup=true
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done

    if [[ $EUID -eq 0 ]]; then
        error "Do not run as root. This script will modify /etc/pacman.d/mirrorlist"
        error "Run without sudo, the script will use sudo internally."
        exit 1
    fi

    check_dependencies || exit 1

    if [[ ! -f "$MIRRORLIST" ]]; then
        error "${MIRRORLIST} not found"
        exit 1
    fi

    if [[ "$do_backup" == true ]]; then
        create_backup
    fi

    rank_mirrors
}

main "$@"
