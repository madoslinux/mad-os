#!/usr/bin/env python3
"""madOS OTA Update CLI.

Main CLI for checking and installing OTA updates.
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent / "lib"))

from mados_update.downloader import Downloader
from mados_update.installer import Installer
from mados_update.backup import BackupManager
from mados_update.version import VersionManager


VERSION_FILE = Path("/etc/mados/version.json")
REPO = "madoslinux/mad-os"


def notify(title: str, message: str) -> None:
    """Send desktop notification."""
    if os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
        try:
            subprocess.run(
                ["notify-send", "-u", "normal", title, message, "-i", "system-software-update"],
                capture_output=True,
            )
        except Exception:
            pass


def cmd_check(args: argparse.Namespace) -> int:
    """Check for available updates."""
    version_manager = VersionManager()
    current = version_manager.get_version()
    channel = args.channel or current.get("update_channel", "stable")

    print(f"Checking for updates ({channel} channel)...")

    update_info = Downloader.check_for_updates(current, channel)

    if not update_info:
        print("✓ System is up to date")
        version_manager.update_last_check()
        return 0

    print(f"\n📦 Updates available: {update_info.latest_version}")
    print(f"   Release date: {update_info.release_date}")

    if update_info.system_update:
        print("\n🔄 System update available")

    if update_info.app_updates:
        print("\n📱 Application updates:")
        for app, (old_ver, new_ver) in update_info.app_updates.items():
            print(f"   • {app}: {old_ver} → {new_ver}")

    version_manager.update_last_check()
    return 0


def cmd_install(args: argparse.Namespace) -> int:
    """Install available updates."""
    version_manager = VersionManager()
    current = version_manager.get_version()
    channel = args.channel or current.get("update_channel", "stable")

    print(f"Installing updates ({channel} channel)...")

    update_info = Downloader.check_for_updates(current, channel)

    if not update_info:
        print("✓ No updates available")
        return 0

    downloader = Downloader()
    release = downloader.get_latest_release(channel)

    if not release:
        print("Error: Could not fetch release information", file=sys.stderr)
        return 1

    print(f"Downloading {release.version}...")

    update_dir = downloader.download_update(release)

    if not update_dir:
        print("Error: Download failed", file=sys.stderr)
        return 1

    installer = Installer()

    print("Creating backup...")
    backup_manager = BackupManager()
    backup = backup_manager.create_backup()

    if backup:
        print(f"  Backup created: {backup.name}")
    else:
        print("  Warning: Backup failed")

    if args.system:
        print("\nUpdating system packages...")
        installer.run_pacman_update()

    print("\nInstalling update...")
    if not installer.install_update(update_dir):
        print("Error: Installation failed", file=sys.stderr)

        if backup:
            print("\nAttempting rollback...")
            if installer.rollback(backup.name):
                print("  Rollback successful")
            else:
                print("  Rollback failed", file=sys.stderr)

        return 1

    print("\n✅ Update installed successfully!")
    notify("madOS Actualizado", f"Versión {update_info.latest_version} instalada")

    downloader.cleanup()
    return 0


def cmd_info(args: argparse.Namespace) -> int:
    """Show version information."""
    version_manager = VersionManager()
    version_manager.print_info()
    return 0


def cmd_rollback(args: argparse.Namespace) -> int:
    """Rollback to a previous version."""
    backup_manager = BackupManager()

    if args.list:
        backups = backup_manager.list_backups()
        if not backups:
            print("No backups available")
            return 0

        print("Available backups:")
        for backup in backups:
            print(f"  • {backup['name']} - {backup['version']} - {backup['timestamp']}")
        return 0

    backup_name = args.name

    if not backup_name:
        backup = backup_manager.get_latest_backup()
        if backup:
            backup_name = backup.name
        else:
            print("No backups available", file=sys.stderr)
            return 1

    print(f"Rolling back to {backup_name}...")

    installer = Installer()
    if installer.rollback(backup_name):
        print("✅ Rollback successful!")
        notify("madOS Rollback", f"Restaurado a {backup_name}")
        return 0
    else:
        print("❌ Rollback failed", file=sys.stderr)
        return 1


def cmd_channel(args: argparse.Namespace) -> int:
    """Set update channel."""
    version_manager = VersionManager()
    version_data = version_manager.get_version()
    version_data["update_channel"] = args.channel
    version_manager.set_version(version_data)
    print(f"Update channel set to: {args.channel}")
    return 0


def cmd_auto_update(args: argparse.Namespace) -> int:
    """Configure auto-update."""
    version_manager = VersionManager()

    if args.enable:
        version_manager.set_auto_update(True)
        print("Auto-update enabled")
    elif args.disable:
        version_manager.set_auto_update(False)
        print("Auto-update disabled")
    else:
        current = version_manager.get_version()
        auto = current.get("auto_update", False)
        status = "enabled" if auto else "disabled"
        print(f"Auto-update: {status}")

    return 0


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="madOS OTA Update System",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    check_parser = subparsers.add_parser("check", help="Check for updates")
    check_parser.add_argument(
        "--channel", choices=["stable", "beta"], help="Update channel"
    )

    install_parser = subparsers.add_parser("install", help="Install updates")
    install_parser.add_argument(
        "--channel", choices=["stable", "beta"], help="Update channel"
    )
    install_parser.add_argument(
        "--system", action="store_true", help="Also update system packages"
    )

    subparsers.add_parser("info", help="Show version information")

    rollback_parser = subparsers.add_parser("rollback", help="Rollback to previous version")
    rollback_parser.add_argument("--name", help="Backup name to restore")
    rollback_parser.add_argument(
        "--list", action="store_true", help="List available backups"
    )

    channel_parser = subparsers.add_parser("channel", help="Set update channel")
    channel_parser.add_argument(
        "channel", choices=["stable", "beta"], help="Channel to use"
    )

    auto_parser = subparsers.add_parser("auto-update", help="Configure auto-update")
    auto_parser.add_argument(
        "--enable", action="store_true", help="Enable auto-update"
    )
    auto_parser.add_argument(
        "--disable", action="store_true", help="Disable auto-update"
    )

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 0

    commands = {
        "check": cmd_check,
        "install": cmd_install,
        "info": cmd_info,
        "rollback": cmd_rollback,
        "channel": cmd_channel,
        "auto-update": cmd_auto_update,
    }

    return commands[args.command](args)


if __name__ == "__main__":
    sys.exit(main())