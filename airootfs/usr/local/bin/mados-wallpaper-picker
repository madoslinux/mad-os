#!/usr/bin/env bash
set -euo pipefail

ACTION="${1:-toggle}"
DAEMON_QML="/usr/local/share/skwd-wall/daemon.qml"
SERVICE_NAME="skwd-wall.service"
LOG_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/mados/skwd-wall.log"

notify_error() {
    local message="$1"
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "madOS wallpaper" "$message" 2>/dev/null || true
    fi
}

ensure_log_dir() {
    mkdir -p "$(dirname "$LOG_FILE")"
}

close_qs_overlay() {
    local qs_manager="$HOME/.config/hypr/scripts/qs_manager.sh"
    if [[ -x "$qs_manager" ]]; then
        "$qs_manager" close "" keepfocus >>"$LOG_FILE" 2>&1 || true
        sleep 0.08
    fi
}

daemon_ready() {
    quickshell ipc -p "$DAEMON_QML" show >/dev/null 2>&1
}

start_daemon_service() {
    if daemon_ready; then
        return 0
    fi

    /usr/local/bin/mados-skwd-wall-sources sync >>"$LOG_FILE" 2>&1 || true
    if command -v systemctl >/dev/null 2>&1; then
        systemctl --user start "$SERVICE_NAME" >>"$LOG_FILE" 2>&1 || true
    fi

    if ! daemon_ready; then
        setsid -f /usr/local/bin/mados-skwd-wall-daemon >>"$LOG_FILE" 2>&1 || true
    fi

    local tries=0
    while [[ $tries -lt 40 ]]; do
        if daemon_ready; then
            return 0
        fi
        sleep 0.1
        tries=$((tries + 1))
    done

    return 1
}

ipc_call() {
    local method="$1"
    quickshell ipc -p "$DAEMON_QML" call wallpaper "$method" >>"$LOG_FILE" 2>&1
}

main() {
    ensure_log_dir

    if [[ ! -f "$DAEMON_QML" ]]; then
        notify_error "skwd-wall no esta instalado en /usr/local/share/skwd-wall"
        exit 1
    fi

    if ! command -v quickshell >/dev/null 2>&1; then
        notify_error "quickshell no esta instalado"
        exit 1
    fi

    case "$ACTION" in
        daemon)
            exec /usr/local/bin/mados-skwd-wall-daemon
            ;;
        toggle|open)
            close_qs_overlay
            start_daemon_service || {
                notify_error "no se pudo iniciar el daemon de skwd-wall"
                exit 1
            }
            ;;
        close)
            if ! daemon_ready; then
                exit 0
            fi
            ;;
        *)
            ACTION="toggle"
            close_qs_overlay
            start_daemon_service || {
                notify_error "no se pudo iniciar el daemon de skwd-wall"
                exit 1
            }
            ;;
    esac

    if ! ipc_call "$ACTION"; then
        notify_error "no se pudo controlar skwd-wall"
        exit 1
    fi
}

main "$@"
