#!/bin/bash
# start-hyprland - COMPLETELY SILENT wrapper for Hyprland with fallback to Sway
LOG_TAG="start-hyprland"
MIN_RUNTIME=5

logger -p user.info -t "$LOG_TAG" "Preparing Hyprland"

export XDG_SESSION_TYPE="wayland"
export XDG_CURRENT_DESKTOP="Hyprland"
export MOZ_ENABLE_WAYLAND=1
export LIBSEAT_BACKEND=logind

# AGGRESSIVELY SILENCE ALL LOGGING
export WLR_LOG_LEVEL=error
export HYPRLAND_LOG_DISABLED=1
export G_MESSAGES_DEBUG=
export GIO_USE_UDEV=0
export QT_LOGGING_RULES="*.debug=false;*.info=false;*.warning=false;*.critical=false"
export WAYLAND_DEBUG=
export EC_LOG_LEVEL=error
export NIXOS_OSTYPE_SHOULDBE=linux

# Detect VM or legacy hardware → software rendering
USE_SOFTWARE=0
systemd-detect-virt --vm --quiet 2>/dev/null && USE_SOFTWARE=1
[ -x /usr/local/bin/detect-legacy-hardware ] && /usr/local/bin/detect-legacy-hardware >/dev/null 2>&1 && USE_SOFTWARE=1

if [ $USE_SOFTWARE -eq 1 ]; then
    export WLR_RENDERER=pixman
    export WLR_NO_HARDWARE_CURSORS=1
    export LIBGL_ALWAYS_SOFTWARE=1
    export GSK_RENDERER=cairo
    export MESA_GL_VERSION_OVERRIDE=3.3
fi

command -v Hyprland >/dev/null 2>&1 || { logger -p user.err -t "$LOG_TAG" "Hyprland not found"; exit 1; }
[ -x /usr/local/bin/detect-legacy-hardware ] && /usr/local/bin/detect-legacy-hardware >/dev/null 2>&1 && exit 1

exec {WATCHDOG_FD}>/dev/null
start_time=$(date +%s)
Hyprland --watchdog-fd "$WATCHDOG_FD" </dev/null >/dev/null 2>&1
exit_code=$?
end_time=$(date +%s)
exec {WATCHDOG_FD}>&-

runtime=$((end_time - start_time))
if [ $runtime -lt $MIN_RUNTIME ]; then
    logger -p user.err -t "$LOG_TAG" "Hyprland crashed after ${runtime}s - legacy hardware likely"
    exit 1
fi
exit $exit_code
