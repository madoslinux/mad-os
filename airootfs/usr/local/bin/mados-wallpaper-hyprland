#!/usr/bin/env bash
# mados-wallpaper-hyprland - Random per-workspace wallpapers for Hyprland

WALLPAPER_DIR="${WALLPAPER_DIR:-/usr/share/backgrounds}"
MAX_WORKSPACES=6
LOG_TAG="mados-wallpaper-hyprland"
DB_DIR="${HOME}/.local/share/mados"
DB_PATH="${DB_DIR}/wallpapers.db"
SOCKET_PATH="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"
MATUGEN_RELOAD_SCRIPT="${HOME}/.config/quickshell/widgets/wallpaper/matugen_reload.sh"
MATUGEN_STATE_FILE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/mados-last-matugen-wallpaper"

log() {
    logger -p user.info -t "$LOG_TAG" "$*" 2>/dev/null || true
    echo "$LOG_TAG: $*" >&2
}

cleanup() {
    log "daemon exiting"
}
trap cleanup EXIT

kill_previous() {
    local my_pid=$$
    local pids
    pids="$(pgrep -f "mados-wallpaper-hyprland" 2>/dev/null)" || true
    for pid in $pids; do
        if [[ "$pid" != "$my_pid" ]]; then
            kill "$pid" 2>/dev/null || true
        fi
    done
}

init_db() {
    mkdir -p "$DB_DIR"
    sqlite3 "$DB_PATH" <<'SQL'
PRAGMA journal_mode=WAL;
CREATE TABLE IF NOT EXISTS wallpapers (
    id   INTEGER PRIMARY KEY AUTOINCREMENT,
    path TEXT    UNIQUE NOT NULL
);
CREATE TABLE IF NOT EXISTS assignments (
    workspace    INTEGER PRIMARY KEY,
    wallpaper_id INTEGER NOT NULL REFERENCES wallpapers(id)
);
SQL
}

sync_wallpapers_to_db() {
    local file escaped count
    shopt -s nullglob
    for file in "$WALLPAPER_DIR"/*.{png,jpg,jpeg,webp}; do
        escaped="${file//\'/\'\'}"
        sqlite3 "$DB_PATH" "INSERT OR IGNORE INTO wallpapers(path) VALUES('$escaped');"
    done
    shopt -u nullglob

    count="$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM wallpapers;")"
    [[ "$count" -gt 0 ]]
}

collect_wallpapers() {
    WALLPAPERS=()
    while IFS='|' read -r wid wpath; do
        WALLPAPERS+=("$wid|$wpath")
    done < <(sqlite3 "$DB_PATH" "SELECT id, path FROM wallpapers ORDER BY path;")
    [[ ${#WALLPAPERS[@]} -gt 0 ]]
}

shuffle_wallpapers() {
    local i j tmp
    for (( i=${#WALLPAPERS[@]}-1; i>0; i-- )); do
        j=$(( RANDOM % (i+1) ))
        tmp="${WALLPAPERS[i]}"
        WALLPAPERS[i]="${WALLPAPERS[j]}"
        WALLPAPERS[j]="$tmp"
    done
}

assign_wallpapers() {
    local ws has idx entry wid
    for (( ws=1; ws<=MAX_WORKSPACES; ws++ )); do
        has="$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM assignments WHERE workspace=$ws;")"
        if [[ "$has" -eq 0 ]]; then
            idx=$(( (ws - 1) % ${#WALLPAPERS[@]} ))
            entry="${WALLPAPERS[$idx]}"
            wid="${entry%%|*}"
            sqlite3 "$DB_PATH" "INSERT OR REPLACE INTO assignments(workspace, wallpaper_id) VALUES($ws, $wid);"
        fi
    done
}

get_wallpaper_for_ws() {
    local ws="$1"
    sqlite3 "$DB_PATH" "SELECT w.path FROM assignments a JOIN wallpapers w ON a.wallpaper_id=w.id WHERE a.workspace=$ws LIMIT 1;"
}

set_wallpaper() {
    local wallpaper="$1"
    local use_transition="${2:-true}"
    [[ -n "$wallpaper" && -f "$wallpaper" ]] || return 1

    if [[ "$use_transition" == "false" ]]; then
        swww img "$wallpaper" --transition-type none 2>/dev/null || return 1
    else
        swww img "$wallpaper" \
            --transition-type pixelate \
            --transition-duration 0.4 \
            --transition-fps 60 \
            --transition-step 90 2>/dev/null || return 1
    fi
}

apply_matugen() {
    local wallpaper="$1"
    local last_applied=""

    [[ -n "$wallpaper" && -f "$wallpaper" ]] || return 0

    if [[ -f "$MATUGEN_STATE_FILE" ]]; then
        last_applied="$(<"$MATUGEN_STATE_FILE")"
        [[ "$last_applied" == "$wallpaper" ]] && return 0
    fi

    command -v matugen >/dev/null 2>&1 || return 0
    [[ -f "$MATUGEN_RELOAD_SCRIPT" ]] || return 0

    if matugen image "$wallpaper" --source-color-index 0 >/dev/null 2>&1; then
        bash "$MATUGEN_RELOAD_SCRIPT" >/dev/null 2>&1 || true
        mkdir -p "$(dirname "$MATUGEN_STATE_FILE")"
        printf '%s\n' "$wallpaper" > "$MATUGEN_STATE_FILE" 2>/dev/null || true
    fi
}

wait_swww() {
    local attempt
    for attempt in $(seq 1 30); do
        if swww query >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.2
    done
    return 1
}

for cmd in hyprctl jq sqlite3 swww socat matugen; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        log "missing command: $cmd"
        exit 0
    fi
done

if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
    log "HYPRLAND_INSTANCE_SIGNATURE not found"
    exit 0
fi

kill_previous
init_db
sync_wallpapers_to_db || exit 0
collect_wallpapers || exit 0
shuffle_wallpapers
assign_wallpapers

if ! swww query >/dev/null 2>&1; then
    swww-daemon &
    disown
fi
wait_swww || exit 0

last_ws="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id // 1' 2>/dev/null)"
[[ -z "$last_ws" || "$last_ws" == "null" ]] && last_ws=1

initial_wallpaper="$(get_wallpaper_for_ws "$last_ws")"
set_wallpaper "$initial_wallpaper" "false" || true
apply_matugen "$initial_wallpaper"

while IFS= read -r event; do
    [[ "$event" == workspace\>\>* ]] || continue
    ws="${event#workspace>>}"
    ws="${ws%%,*}"
    [[ "$ws" =~ ^[0-9]+$ ]] || continue
    (( ws >= 1 && ws <= MAX_WORKSPACES )) || continue
    [[ "$ws" == "$last_ws" ]] && continue

    wallpaper="$(get_wallpaper_for_ws "$ws")"
    if set_wallpaper "$wallpaper"; then
        apply_matugen "$wallpaper"
        last_ws="$ws"
    fi
done < <(socat -U - UNIX-CONNECT:"$SOCKET_PATH" 2>/dev/null)
