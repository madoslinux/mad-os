#!/bin/bash
# detect-legacy-hardware - Detecta hardware antiguo que requiere renderizado por software
# Retorna 0 si se detecta hardware antiguo, 1 si es hardware moderno
# VMs con aceleración 3D NO se consideran legacy (usan hardware rendering con workarounds DRM)

# Función para detectar si hay aceleración 3D disponible
detect_3d_acceleration() {
    # Verificar si existe un render node DRM (indica GPU con aceleración)
    if [ -e /dev/dri/renderD128 ]; then
        # Verificar driver DRM para determinar capacidades
        local drm_driver=""
        for card in /sys/class/drm/card*/device/driver; do
            if [ -L "$card" ]; then
                drm_driver=$(basename "$(readlink "$card")")
                break
            fi
        done
        
        # Drivers de VM con aceleración 3D confirmada
        case "$drm_driver" in
            vboxvideo|virtio-gpu|virgl)
                # VMs con aceleración 3D habilitada
                return 0
                ;;
            vmwgfx)
                # VMware: verificar si hay aceleración OpenGL vía glxinfo o lspci
                # vmwgfx carga incluso sin 3D, necesitamos verificación extra
                if command -v lspci >/dev/null 2>&1; then
                    if lspci | grep -qi "3D\|SVGA"; then
                        return 0
                    fi
                fi
                # Asumir que vmwgfx tiene aceleración básica
                return 0
                ;;
            i915|i915_gem|i2c_i915)
                # Intel modernas (HD/UHD/Iris) - siempre tienen aceleración
                return 0
                ;;
            amdgpu|radeon)
                # AMD GPUs - todas tienen aceleración
                return 0
                ;;
            nvidia|nvidiafb|nouveau)
                # NVIDIA - tienen aceleración
                return 0
                ;;
            *)
                # Driver desconocido pero hay renderD128 - asumir aceleración
                return 0
                ;;
        esac
    fi
    
    # Sin renderD128 - verificar si es VM (puede tener aceleración por virtio/vbox)
    if systemd-detect-virt --vm --quiet 2>/dev/null; then
        # Verificar si hay dispositivos DRM de VM
        for driver in vboxvideo virtio-gpu vmwgfx virgl; do
            if [ -d "/sys/module/$driver" ]; then
                return 0
            fi
        done
    fi
    
    return 1
}

# Función para detectar CPUs antiguas
detect_legacy_cpu() {
    local cpu_info=$(cat /proc/cpuinfo 2>/dev/null)
    
    # Detectar Intel Atom (Bonnell, Saltwell, Silvermont, Airmont, Goldmont, Goldmont Plus)
    if echo "$cpu_info" | grep -qi "Atom\|Celeron N\|Pentium N"; then
        return 0
    fi
    
    # Detectar CPUs muy antiguas por familia/modelo
    local cpu_family=$(grep -m1 "^cpu family" /proc/cpuinfo | awk '{print $4}')
    local model=$(grep -m1 "^model[[:space:]]" /proc/cpuinfo | awk '{print $3}')
    
    # Intel Core antiguo (antes de Sandy Bridge - familia 6, modelo < 42)
    if [ "$cpu_family" = "6" ] && [ "$model" -lt "42" ] 2>/dev/null; then
        return 0
    fi
    
    # CPUs con frecuencia muy baja (< 1.5 GHz)
    local max_freq=$(lscpu | grep "CPU max MHz" | awk '{print $NF}')
    if [ -n "$max_freq" ]; then
        if awk -v freq="$max_freq" 'BEGIN {exit !(freq < 1500)}'; then
            return 0
        fi
    fi
    
    return 1
}

# Función para detectar GPUs antiguas de Intel
detect_legacy_intel_gpu() {
    local gpu_info=$(lspci 2>/dev/null | grep -i "VGA\|3D\|Display" | grep -i intel)
    
    if [ -z "$gpu_info" ]; then
        return 1  # No es Intel
    fi
    
    # GPUs antiguas que tienen problemas con aceleración
    # Gen 1-4: i810, i815, i830, i845, i855, i865, i915, i945
    # Gen 5-6: GMA 950, GMA 3000, GMA X3000, GMA X3100, GMA X3500
    if echo "$gpu_info" | grep -qiE "810|815|830|845|855|865|915|945|GMA|Gen[1-6]"; then
        return 0
    fi
    
    # Atom GPUs integradas (PowerVR-based)
    if echo "$gpu_info" | grep -qiE "Atom|Poulsbo|US15|GMA 500|GMA 600|GMA 3600|GMA 3650"; then
        return 0
    fi
    
    return 1
}

# Función para detectar GPUs antiguas de NVIDIA
detect_legacy_nvidia_gpu() {
    local gpu_info=$(lspci 2>/dev/null | grep -i "VGA\|3D\|Display" | grep -i nvidia)
    
    if [ -z "$gpu_info" ]; then
        return 1  # No es NVIDIA
    fi
    
    # NVIDIA GPUs antiguas que no soportan el driver propietario actual ni nouveau adecuadamente
    # GeForce FX (NV3x) y anteriores: GeForce 256, GeForce2, GeForce3, GeForce4, GeForce FX
    # GeForce 6/7 series (NV4x/G7x): soporte nouveau limitado
    # Quadro FX antiguas
    if echo "$gpu_info" | grep -qiE "GeForce (FX|[2-4][0-9]{2}[^0-9]|256|MX|Ti |PCX)"; then
        return 0
    fi
    if echo "$gpu_info" | grep -qiE "Quadro (FX|NVS [0-9]{2}[^0-9]|[0-9]{3}[^0-9])"; then
        return 0
    fi
    if echo "$gpu_info" | grep -qiE "NV[0-3][0-9A-Fa-f]|C51|C61|C67|C68|C73|MCP"; then
        return 0
    fi
    # GeForce 6xxx/7xxx series
    if echo "$gpu_info" | grep -qiE "GeForce [67][0-9]{3}"; then
        return 0
    fi
    
    return 1
}

# Función para detectar GPUs antiguas de AMD/ATI
detect_legacy_amd_gpu() {
    local gpu_info=$(lspci 2>/dev/null | grep -i "VGA\|3D\|Display" | grep -iE "AMD|ATI|Radeon")
    
    if [ -z "$gpu_info" ]; then
        return 1  # No es AMD/ATI
    fi
    
    # GPUs AMD/ATI antiguas que no soportan amdgpu driver (usan radeon driver)
    # R100-R500: Radeon 7000-X1950 (muy antiguas, sin soporte adecuado)
    # R600-R700: Radeon HD 2000-4000 (soporte radeon driver, sin Vulkan)
    if echo "$gpu_info" | grep -qiE "Radeon (7[0-9]{3}|8[0-9]{3}|9[0-9]{3}|X[0-9]{3,4})"; then
        return 0
    fi
    if echo "$gpu_info" | grep -qiE "Radeon HD [2-4][0-9]{3}"; then
        return 0
    fi
    # ATI Rage, Mach series
    if echo "$gpu_info" | grep -qiE "Rage|Mach[0-9]|RS[0-9]{3}|RV[0-9]{3}"; then
        return 0
    fi
    # FireGL/FirePro antiguas
    if echo "$gpu_info" | grep -qiE "Fire(GL|Pro) [VT][0-9]{1,4}"; then
        return 0
    fi
    
    return 1
}

# Función para detectar sistemas con RAM muy baja
detect_low_ram() {
    local total_ram_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    local total_ram_mb=$((total_ram_kb / 1024))
    
    # Menos de 2GB de RAM
    if [ "$total_ram_mb" -lt 2048 ]; then
        return 0
    fi
    
    return 1
}

# Detección principal
main() {
    local legacy_reason=""
    
    # Detectar nomodeset (safe graphics mode) - siempre es legacy
    if grep -q 'nomodeset' /proc/cmdline 2>/dev/null; then
        echo "nomodeset detected"
        return 0
    fi
    
    # Detectar máquina virtual
    if systemd-detect-virt --vm --quiet 2>/dev/null; then
        # VM con aceleración 3D: NO es legacy (usará hardware rendering con workarounds DRM)
        if detect_3d_acceleration; then
            echo "VM with 3D acceleration detected"
            return 1
        fi
        # VM sin aceleración 3D: es legacy (necesita pixman)
        echo "VM without 3D acceleration detected"
        return 0
    fi
    
    # Detectar CPU antigua
    if detect_legacy_cpu; then
        legacy_reason="${legacy_reason}Legacy CPU;"
    fi
    
    # Detectar GPU Intel antigua
    if detect_legacy_intel_gpu; then
        legacy_reason="${legacy_reason}Legacy Intel GPU;"
    fi
    
    # Detectar GPU NVIDIA antigua
    if detect_legacy_nvidia_gpu; then
        legacy_reason="${legacy_reason}Legacy NVIDIA GPU;"
    fi
    
    # Detectar GPU AMD/ATI antigua
    if detect_legacy_amd_gpu; then
        legacy_reason="${legacy_reason}Legacy AMD/ATI GPU;"
    fi
    
    # Detectar RAM baja
    if detect_low_ram; then
        legacy_reason="${legacy_reason}Low RAM;"
    fi
    
    # Si se detectó alguna razón, retornar hardware antiguo
    if [ -n "$legacy_reason" ]; then
        echo "Legacy hardware detected: $legacy_reason"
        return 0
    fi
    
    # Verificar aceleración 3D en hardware físico (no solo en VMs)
    # Si no hay aceleración 3D disponible, tratar como legacy
    if ! detect_3d_acceleration; then
        echo "No 3D acceleration detected"
        return 0
    fi
    
    # Hardware moderno
    echo "Modern hardware detected"
    return 1
}

# Ejecutar detección
main "$@"
