#!/usr/bin/env python3
"""
mados-welcome - Welcome application for madOS
GTK4-based welcome screen for post-installation setup

Features:
- Welcome message and system info
- Quick access to common tasks
- Driver installation (via mados-chwd)
- DE/WM selection
- Mirror ranking
"""

import subprocess
import sys
import gi

gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gtk, Adw, GLib


class WelcomeWindow(Adw.Application):
    def __init__(self):
        super().__init__(application_id="org.mados.Welcome")
        self.connect("activate", self.on_activate)

    def on_activate(self, app):
        self.win = Adw.ApplicationWindow(application=app, default_width=700, default_height=500)
        self.win.set_title("madOS Welcome")

        self.setup_ui()

        self.win.present()

    def setup_ui(self):
        self.toast_overlay = Adw.ToastOverlay()
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=20)
        main_box.set_margin_top(20)
        main_box.set_margin_bottom(20)
        main_box.set_margin_start(20)
        main_box.set_margin_end(20)

        header = Adw.HeaderBar()
        header.set_title("Welcome to madOS")

        status_page = Adw.StatusPage(
            title="Welcome to madOS",
            subtitle="Your AI-orchestrated Arch Linux distribution",
            icon_name="system-os-install-symbolic"
        )
        main_box.append(status_page)

        action_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        action_box.set_margin_top(20)

        buttons = [
            ("Install Drivers", "Driver installation for NVIDIA, AMD, Intel", "computer-symbolic", self.on_install_drivers),
            ("Configure Desktop", "Select window manager and appearance", "preferences-desktop-symbolic", self.on_configure_desktop),
            ("Rank Mirrors", "Find fastest Arch Linux mirrors", "network-server-symbolic", self.on_rank_mirrors),
            ("Create Snapshot", "Create Btrfs snapshot for recovery", "drive-harddisk-symbolic", self.on_create_snapshot),
            ("Check Updates", "Check for system updates", "software-update-available-symbolic", self.on_check_updates),
        ]

        for label, desc, icon, callback in buttons:
            btn = Adw.ActionRow(title=label, subtitle=desc)
            img = Gtk.Image.new_from_icon_name(icon)
            img.set_icon_size(Gtk.IconSize.LARGE)
            btn.add_prefix(img)
            btn.connect("activated", callback)
            action_box.append(btn)

        view_stack = Gtk.Stack()
        view_stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)

        welcome_view = Gtk.ScrolledWindow()
        welcome_view.set_child(main_box)

        status_view = self.create_status_view()
        view_stack.add_titled(status_view, "status", "System Status")
        view_stack.add_titled(welcome_view, "welcome", "Welcome")

        self.toast_overlay.set_child(view_stack)

        clamp = Adw.Clamp()
        clamp.set_child(self.toast_overlay)
        clamp.set_maximum_size(600)
        clamp.set_margin_start(40)
        clamp.set_margin_end(40)

        content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        content_box.append(clamp)

        self.win.set_content(content_box)

    def create_status_view(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.set_margin_top(20)
        box.set_margin_bottom(20)
        box.set_margin_start(20)
        box.set_margin_end(20)

        status_page = Adw.StatusPage(
            title="System Status",
            icon_name="dialog-information-symbolic"
        )
        box.append(status_page)

        return box

    def run_command(self, cmd, description):
        try:
            result = subprocess.run(
                cmd,
                shell=True,
                capture_output=True,
                text=True,
                timeout=120
            )
            toast = Adw.Toast(title=f"{description} - {'Success' if result.returncode == 0 else 'Failed'}")
            self.toast_overlay.add_toast(toast)
            return result
        except subprocess.TimeoutExpired:
            toast = Adw.Toast(title=f"{description} - Timeout")
            self.toast_overlay.add_toast(toast)
            return None

    def on_install_drivers(self, btn):
        toast = Adw.Toast(title="Running hardware detection...")
        toast.set_timeout(3)
        self.toast_overlay.add_toast(toast)
        self.run_command("mados-chwd --autoconfigure", "Driver installation")

    def on_configure_desktop(self, btn):
        toast = Adw.Toast(title="Desktop configuration...")
        self.toast_overlay.add_toast(toast)
        self.run_command("mados-select-desktop", "Desktop configuration")

    def on_rank_mirrors(self, btn):
        toast = Adw.Toast(title="Ranking mirrors (this may take a minute)...")
        self.toast_overlay.add_toast(toast)
        self.run_command("mados-rate-mirrors", "Mirror ranking")

    def on_create_snapshot(self, btn):
        toast = Adw.Toast(title="Creating snapshot...")
        self.toast_overlay.add_toast(toast)
        self.run_command("mados-snapper create pre-update", "Snapshot creation")

    def on_check_updates(self, btn):
        toast = Adw.Toast(title="Checking for updates...")
        self.toast_overlay.add_toast(toast)
        self.run_command("pacman -Syu --noconfirm", "System update")


def main():
    app = WelcomeWindow()
    return app.run(sys.argv)


if __name__ == "__main__":
    sys.exit(main())
