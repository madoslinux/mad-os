#!/usr/bin/env bash
# madOS Installer Autostart Helper
# Launched by Sway/Hyprland config - checks conditions and starts the GTK installer
# Only runs in live environment (archiso) and NOT when booted via Ventoy

LOG="/var/log/mados-installer-autostart.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG" 2>/dev/null
}

is_ventoy_boot() {
    if [ -f /proc/cmdline ]; then
        grep -q "ventoy" /proc/cmdline && return 0
    fi
    return 1
}

fix_pacman_db() {
    # Skip pacman DB fix in autostart - it's handled in welcome script
    log "Skipping pacman DB fix in autostart (handled elsewhere)"
}

# Only launch installer if in archiso live environment and NOT in Ventoy mode
if [ ! -d /run/archiso ]; then
    log "Not in archiso live environment, skipping installer autostart"
    exit 0
fi

if is_ventoy_boot; then
    log "Ventoy boot detected, skipping installer autostart"
    exit 0
fi

log "Live environment detected, launching installer..."

# Fix pacman DB in live environment (uses polkit but with rules)
log "Fixing pacman DB..."
pkexec pacman-key --init 2>/dev/null || true
pkexec pacman-key --populate 2>/dev/null || true
if command -v pacman-db-upgrade &>/dev/null; then
    pkexec pacman-db-upgrade 2>/dev/null || true
fi
log "Pacman DB fixed"

# Ensure GTK uses the Wayland backend
export GDK_BACKEND=wayland

# Get the current user's display and runtime dir
CURRENT_USER=$(whoami)
WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u $CURRENT_USER)}"

log "Current user: $CURRENT_USER"
log "WAYLAND_DISPLAY: $WAYLAND_DISPLAY"
log "XDG_RUNTIME_DIR: $XDG_RUNTIME_DIR"

sleep 2

# Run installer (as root since autostart runs as root via su)
if [ -x /usr/local/bin/install-mados ]; then
    log "Starting install-mados"
    # Execute directly (running as root already)
    /usr/local/bin/install-mados
    EXIT_CODE=$?
    log "Installer exited with code: $EXIT_CODE"
else
    log "ERROR: /usr/local/bin/install-mados not found or not executable"
    exit 1
fi
