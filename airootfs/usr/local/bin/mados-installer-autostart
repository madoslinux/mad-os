#!/usr/bin/env bash
# madOS Installer Autostart Helper
# Launched by Sway config - checks conditions and starts the GTK installer
# Only runs in live environment (archiso) and NOT when booted via Ventoy

LOG_DIR="/run/user/$(id -u)"
LOG="$LOG_DIR/mados-installer-autostart.log"
LOCK_DIR="$LOG_DIR/mados-installer-autostart.lock"
mkdir -p "$LOG_DIR"

log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $*"
    echo "$msg" >> "$LOG"
    echo "$msg" >> /dev/ttyS0 2>/dev/null || true
}

log "Starting autostart as user: $(whoami) uid: $(id -u)"

# Avoid duplicate launches from multiple autostart entry points
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    log "Autostart lock exists, installer already running/launched; exiting"
    exit 0
fi
trap 'rm -rf "$LOCK_DIR"' EXIT

is_ventoy_boot() {
    if [ -f /proc/cmdline ]; then
        grep -q "ventoy" /proc/cmdline && return 0
    fi
    return 1
}

fix_pacman_db() {
    # Skip pacman DB fix in autostart - it's handled in welcome script
    log "Skipping pacman DB fix in autostart (handled elsewhere)"
}

# Only launch installer if in archiso live environment and NOT in Ventoy mode
if [ ! -d /run/archiso ]; then
    log "Not in archiso live environment, skipping installer autostart"
    exit 0
fi

if is_ventoy_boot; then
    log "Ventoy boot detected, skipping installer autostart"
    exit 0
fi

log "Live environment detected, launching installer..."

# Get the current user's display and runtime dir
CURRENT_USER=$(whoami)
XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u "$CURRENT_USER")}"

log "Current user: $CURRENT_USER"
log "XDG_RUNTIME_DIR: $XDG_RUNTIME_DIR"

sleep 2

# Run installer (should be running as root now)
log "Running as user: $(whoami) with uid: $(id -u)"
INSTALLER_PATH="/usr/local/bin/mados-installer"
if [ -x "$INSTALLER_PATH" ]; then
    log "Starting installer: $INSTALLER_PATH"
    sudo -E PATH="$PATH" "$INSTALLER_PATH" >> /dev/ttyS0 2>&1
    EXIT_CODE=$?
    log "Installer exited with code: $EXIT_CODE"
else
    log "ERROR: $INSTALLER_PATH not found"
    ls -la /usr/local/bin/mados-installer 2>&1 || true
    ls -la /opt/mados/mados_installer/ 2>&1 || true
    exit 1
fi
