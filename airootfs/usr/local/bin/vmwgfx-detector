#!/bin/bash
LOG_TAG="vmwgfx-detector"
log() { echo "$1" | systemd-cat -t "$LOG_TAG" -p "${2:-info}" 2>/dev/null; }

is_vmware() {
    [ -f /sys/class/dmi/id/board_vendor ] && grep -qi "vmware" /sys/class/dmi/id/board_vendor 2>/dev/null && return 0
    [ -f /sys/class/dmi/id/product_name ] && grep -qi "vmware" /sys/class/dmi/id/product_name 2>/dev/null && return 0
    [ -f /sys/class/dmi/id/sys_vendor ] && grep -qi "vmware" /sys/class/dmi/id/sys_vendor 2>/dev/null && return 0
    lspci -d 15ad:0405 >/dev/null 2>&1 && return 0
    return 1
}

if is_vmware; then
    log "VMware detected - vmwgfx ENABLED"
    rm -f /etc/modprobe.d/99-disable-vmwgfx.conf 2>/dev/null
else
    log "NOT VMware - vmwgfx DISABLED"
    cat > /etc/modprobe.d/99-disable-vmwgfx.conf << 'EOFPMD'
install vmwgfx /bin/false
blacklist vmwgfx
EOFPMD
fi
