#!/usr/bin/env bash
set -euo pipefail

export SKWD_WALL_INSTALL="${SKWD_WALL_INSTALL:-/usr/local/share/skwd-wall}"
if [[ ! -d "$SKWD_WALL_INSTALL" && -d "${HOME}/.local/share/skwd-wall" ]]; then
    export SKWD_WALL_INSTALL="${HOME}/.local/share/skwd-wall"
fi
export SKWD_WALL_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/skwd-wall"
SKWD_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/skwd-wall"
UNION_DIR="${SKWD_CACHE_DIR}/wallpaper-union"
STATE_FILE="${SKWD_CACHE_DIR}/source-sync-state.json"

HELPER_BIN_DIR="/usr/local/bin"
if [[ ! -x "${HELPER_BIN_DIR}/mados-skwd-wall-sources" && -x "${HOME}/.local/bin/mados-skwd-wall-sources" ]]; then
    HELPER_BIN_DIR="${HOME}/.local/bin"
fi

if quickshell ipc -p "${SKWD_WALL_INSTALL}/daemon.qml" show >/dev/null 2>&1; then
    exit 0
fi

"${HELPER_BIN_DIR}/mados-skwd-wall-sources" prepare >/dev/null 2>&1 || true

if [[ ! -f "$STATE_FILE" || ! -d "$UNION_DIR" || -z "$(ls -A "$UNION_DIR" 2>/dev/null)" ]]; then
    "${HELPER_BIN_DIR}/mados-skwd-wall-sources" sync >/dev/null 2>&1 || true
else
    "${HELPER_BIN_DIR}/mados-skwd-wall-sources" sync >/dev/null 2>&1 &
fi

exec quickshell -p "${SKWD_WALL_INSTALL}/daemon.qml"
