#!/bin/bash
export XDG_SESSION_TYPE=x11
export XDG_CURRENT_DESKTOP=sway
export MOZ_ENABLE_WAYLAND=0

# Use systemd-logind as the seat management backend (madOS uses systemd)
export LIBSEAT_BACKEND=logind

if [ -x /usr/local/bin/detect-legacy-hardware ]; then
    if /usr/local/bin/detect-legacy-hardware >/dev/null 2>&1; then
        export WLR_RENDERER=pixman
        export WLR_NO_HARDWARE_CURSORS=1
        export LIBGL_ALWAYS_SOFTWARE=1
        export MESA_GL_VERSION_OVERRIDE=3.3
        # GTK: disable Vulkan renderer to avoid GPU probe errors
        export GSK_RENDERER=cairo
        # Chromium: force software rendering on legacy hardware
        export CHROMIUM_FLAGS="${CHROMIUM_FLAGS:-} --disable-gpu"
        logger -p user.info -t mados-sway "Starting sway with software rendering (pixman)"
    fi
else
    if systemd-detect-virt --vm --quiet 2>/dev/null; then
        export WLR_RENDERER=pixman
        export WLR_NO_HARDWARE_CURSORS=1
        export LIBGL_ALWAYS_SOFTWARE=1
        export MESA_GL_VERSION_OVERRIDE=3.3
        # GTK: disable Vulkan renderer to avoid GPU probe errors
        export GSK_RENDERER=cairo
        # Chromium: force software rendering in VMs without 3D
        export CHROMIUM_FLAGS="${CHROMIUM_FLAGS:-} --disable-gpu"
        logger -p user.info -t mados-sway "Starting sway with software rendering (VM fallback)"
    fi
fi

# Force software rendering from kernel cmdline (used by run-qemu --software-render)
if grep -qw "mados.force_software=1" /proc/cmdline 2>/dev/null; then
    export WLR_RENDERER=pixman
    export WLR_NO_HARDWARE_CURSORS=1
    export LIBGL_ALWAYS_SOFTWARE=1
    export MESA_GL_VERSION_OVERRIDE=3.3
    export GSK_RENDERER=cairo
    export CHROMIUM_FLAGS="${CHROMIUM_FLAGS:-} --disable-gpu"
    logger -p user.info -t mados-sway "Forced software rendering via kernel cmdline"
fi

# VM DRM workarounds: disable atomic modesetting and modifiers for VM GPU drivers
if systemd-detect-virt --vm --quiet 2>/dev/null; then
    export WLR_DRM_NO_ATOMIC=1
    export WLR_DRM_NO_MODIFIERS=1
    export WLR_NO_HARDWARE_CURSORS=1

    # VM performance: generate optimized sway config drop-in
    # Reduces visual overhead (no gaps) for smoother experience
    VM_CONF="/etc/sway/config.d/99-vm-performance.conf"
    if [ ! -f "$VM_CONF" ] && [ "$(id -u)" -eq 0 ]; then
        mkdir -p /etc/sway/config.d
        cat > "$VM_CONF" << 'VMCONF'
# Auto-generated VM performance optimizations
# Reduces visual overhead for smoother mouse/input in VirtualBox/VMware/QEMU
# Note: wallpaper is managed by mados-sway-wallpapers, not here
gaps inner 0
gaps outer 0
VMCONF
        logger -p user.info -t mados-sway "Generated VM performance config: $VM_CONF"
    elif [ ! -f "$VM_CONF" ]; then
        logger -p user.info -t mados-sway "VM performance config not writable as user; continuing without /etc drop-in"
    fi
fi

apply_software_rendering() {
    export WLR_RENDERER=pixman
    export WLR_NO_HARDWARE_CURSORS=1
    export LIBGL_ALWAYS_SOFTWARE=1
    export MESA_GL_VERSION_OVERRIDE=3.3
    export GSK_RENDERER=cairo
    export CHROMIUM_FLAGS="${CHROMIUM_FLAGS:-} --disable-gpu"
}

drm_card_available() {
    local card
    for card in /dev/dri/card*; do
        if [ -e "$card" ]; then
            return 0
        fi
    done
    return 1
}

wait_for_drm_card() {
    local retries=10
    local delay=0.3
    local i

    for i in $(seq 1 "$retries"); do
        if drm_card_available; then
            return 0
        fi
        sleep "$delay"
    done
    return 1
}

# Launch sway with fallback to software rendering if hardware rendering fails.
# If software rendering is already configured, exec sway directly.
if ! wait_for_drm_card; then
    logger -p user.warning -t mados-sway "No DRM card device detected before sway launch"
    if [ -x /usr/local/bin/sway-x11-session ]; then
        logger -p user.info -t mados-sway "Backend selected: X11 fallback (vesa/fbdev/dummy)"
        if /usr/local/bin/sway-x11-session; then
            exit 0
        fi
        logger -p user.warning -t mados-sway "sway-x11-session failed, trying i3 fallback"
    fi
    if [ -x /usr/local/bin/mados-i3-session ]; then
        exec /usr/local/bin/mados-i3-session
    fi
    logger -p user.err -t mados-sway "sway-x11-session not available; cannot recover from missing DRM"
    echo "No DRM device found and no X11 fallback is available"
    exit 1
fi

get_edid_native_resolution() {
    local resolution=""
    local edid_file=""
    local display=""

    for conn in /sys/class/drm/card*-*; do
        [ -d "$conn" ] || continue
        status=$(cat "$conn/status" 2>/dev/null || echo "unknown")
        if [ "$status" = "connected" ]; then
            display=$(basename "$conn")
            edid_file="$conn/edid"
            break
        fi
    done

    [ -z "$display" ] && return 1
    [ ! -s "$edid_file" ] && return 1

    if command -v edid-decode >/dev/null 2>&1; then
        local modeline
        modeline=$(edid-decode "$edid_file" 2>/dev/null | grep -m1 "Preferred mode" || true)
        if [ -n "$modeline" ]; then
            resolution=$(echo "$modeline" | grep -oP '\d+x\d+' | head -1 || true)
        fi
    fi

    if [ -z "$resolution" ] && [ -s "$edid_file" ]; then
        local hex_edid
        hex_edid=$(xxd -p "$edid_file" 2>/dev/null | tr -d '\n' || true)
        if [ -n "$hex_edid" ]; then
            local width height
            width=$(printf '%d' "0x${hex_edid:168:4}" 2>/dev/null || true)
            height=$(printf '%d' "0x${hex_edid:172:4}" 2>/dev/null || true)
            if [ -n "$width" ] && [ -n "$height" ] && [ "$width" -gt 0 ] && [ "$height" -gt 0 ]; then
                resolution="${width}x${height}"
            fi
        fi
    fi

    if [ -n "$resolution" ]; then
        echo "$resolution"
        return 0
    fi
    return 1
}

if [ "${WLR_RENDERER:-}" = "pixman" ]; then
    logger -p user.info -t mados-sway "Backend selected: DRM with software renderer (pixman)"
    exec sway
fi

# Try hardware rendering first; if sway exits quickly (< 5s) it likely
# failed during renderer initialisation — retry with pixman.
logger -p user.info -t mados-sway "Backend selected: DRM (native), launching sway compositor"
START_TIME=$(date +%s)

# Check if we need to generate a config with native resolution from EDID
NATIVE_RES=$(get_edid_native_resolution || true)
if [ -n "$NATIVE_RES" ] && [ -f "$HOME/.config/sway/config" ]; then
    SWAY_TMP_CONFIG="${XDG_RUNTIME_DIR:-/tmp}/mados-sway-x11-config.$$"
    cp "$HOME/.config/sway/config" "$SWAY_TMP_CONFIG"
    {
        printf "\n# mados x11 dynamic output mode (EDID native)\n"
        printf "output * mode %s\n" "$NATIVE_RES"
        printf "output * pos 0 0\n"
        printf "output * scale 1\n"
    } >> "$SWAY_TMP_CONFIG"
    logger -p user.info -t mados-sway "X11: using EDID native resolution ${NATIVE_RES}"
    sway -c "$SWAY_TMP_CONFIG"
    EXIT_CODE=$?
else
    sway
    EXIT_CODE=$?
fi
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

if [ $EXIT_CODE -ne 0 ] && [ "$ELAPSED" -lt 5 ]; then
    logger -p user.warning -t mados-sway "Sway failed in ${ELAPSED}s (exit $EXIT_CODE), retrying with software rendering"
    apply_software_rendering
    exec sway
fi
