#!/bin/bash
# mados-set-password - Set mados user password at boot
# Called by systemd service or profile script

if [ -f /run/archiso/bootmnt ]; then
    # Live environment - set password now
    if id mados >/dev/null 2>&1; then
        echo 'mados:mados' | chpasswd 2>/dev/null
        if [ $? -eq 0 ]; then
            logger -p user.info -t mados-password "Password set for mados user"
        else
            logger -p user.err -t mados-password "Failed to set password for mados"
        fi
    fi
fi
