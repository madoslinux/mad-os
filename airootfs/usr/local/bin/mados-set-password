#!/bin/bash
# mados-set-password - Set mados user password at boot
# Called by systemd service before sshd starts

LOG="/var/log/mados-password.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"
    logger -p user.info -t mados-password "$*"
}

log "=== Password Setup Start ==="

# Check if we're in live environment
if [ -f /run/archiso/bootmnt ]; then
    log "Live environment detected"
    
    # Check if mados user exists
    if id mados 2>/dev/null; then
        log "User mados exists, setting password"
        echo 'mados:mados' | chpasswd 2>&1 | tee -a "$LOG"
        if [ $? -eq 0 ]; then
            log "Password set successfully"
        else
            log "Failed to set password"
        fi
    else
        log "User mados does NOT exist - checking shadow file"
        if grep -q '^mados:' /etc/shadow 2>/dev/null; then
            log "mados found in /etc/shadow"
        else
            log "mados NOT in /etc/shadow"
        fi
    fi
else
    log "Not in live environment (no /run/archiso/bootmnt)"
fi

log "=== Password Setup Complete ==="
