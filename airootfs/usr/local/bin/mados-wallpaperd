#!/usr/bin/env bash
# mados-wallpaperd - Unified wallpaper daemon/controller for Sway and Hyprland

set -u

command_name="${1:-start}"
workspace="${2:-}"

detect_compositor() {
    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        echo "hyprland"
        return
    fi
    if [[ -n "${SWAYSOCK:-}" ]]; then
        echo "sway"
        return
    fi
    if pgrep -x Hyprland >/dev/null 2>&1; then
        echo "hyprland"
        return
    fi
    if pgrep -x sway >/dev/null 2>&1; then
        echo "sway"
        return
    fi
    echo "unknown"
}

run_start() {
    case "$(detect_compositor)" in
        hyprland) exec mados-wallpaper-hyprland ;;
        sway) exec mados-sway-wallpapers ;;
        *) exit 0 ;;
    esac
}

run_set() {
    case "$(detect_compositor)" in
        hyprland) exec mados-hyprland-wallpaper-set "$workspace" ;;
        sway) exec mados-sway-wallpaper-set "$workspace" ;;
        *) exit 0 ;;
    esac
}

case "$command_name" in
    start) run_start ;;
    set) run_set ;;
    *)
        echo "Usage: mados-wallpaperd [start|set [workspace]]" >&2
        exit 2
        ;;
esac
