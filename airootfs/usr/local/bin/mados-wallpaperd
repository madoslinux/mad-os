#!/usr/bin/env bash
# mados-wallpaperd - Wallpaper daemon/controller for Sway

set -u

command_name="${1:-start}"
workspace="${2:-}"

run_start() {
    exec mados-sway-wallpapers
}

run_set() {
    exec mados-sway-wallpaper-set "$workspace"
}

case "$command_name" in
    -d|--daemon|start) run_start ;;
    set) run_set ;;
    *)
        echo "Usage: mados-wallpaperd [-d|--daemon|start|set [workspace]]" >&2
        exit 2
        ;;
esac
