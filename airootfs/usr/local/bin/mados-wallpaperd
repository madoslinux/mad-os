#!/usr/bin/env bash
# mados-wallpaperd - Daemon for managing wallpapers
# Maintains SQLite DB and applies wallpapers on workspace changes

set -uo pipefail

DATA_DIR="${HOME}/.local/share/mados"
DB_PATH="${DATA_DIR}/wallpapers.db"
PID_FILE="${DATA_DIR}/mados-wallpaperd.pid"
SYSTEM_WALLPAPERS="/usr/share/backgrounds"
LOG_FILE="${DATA_DIR}/daemon.log"

log() {
    echo "[$(date '+%H:%M:%S')] $*" >&2
}

cleanup() {
    rm -f "$PID_FILE"
    log "Daemon stopped"
}

trap cleanup EXIT

init_db() {
    mkdir -p "$DATA_DIR"
    
    if [[ ! -f "$DB_PATH" ]]; then
        sqlite3 "$DB_PATH" <<'SQL'
PRAGMA journal_mode=WAL;
CREATE TABLE IF NOT EXISTS wallpapers (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    path TEXT UNIQUE NOT NULL
);
CREATE TABLE IF NOT EXISTS assignments (
    workspace INTEGER PRIMARY KEY,
    wallpaper_id INTEGER NOT NULL REFERENCES wallpapers(id),
    mode TEXT DEFAULT 'fill'
);
SQL
        log "Database created at $DB_PATH"
    fi
    
    has_mode=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM pragma_table_info('assignments') WHERE name='mode';" 2>/dev/null || echo "0")
    if [[ "$has_mode" -eq 0 ]]; then
        log "Migrating database: adding mode column..."
        sqlite3 "$DB_PATH" "ALTER TABLE assignments ADD COLUMN mode TEXT DEFAULT 'fill';"
    fi
}

populate_from_system() {
    local count
    count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM wallpapers" 2>/dev/null || echo "0")
    
    if [[ "$count" -gt 0 ]]; then
        log "DB already has $count wallpapers"
        return
    fi
    
    log "DB empty, populating from $SYSTEM_WALLPAPERS..."
    
    if [[ ! -d "$SYSTEM_WALLPAPERS" ]]; then
        log "ERROR: $SYSTEM_WALLPAPERS does not exist"
        return
    fi
    
    shopt -s nullglob
    local files=()
    files=("$SYSTEM_WALLPAPERS"/*.png "$SYSTEM_WALLPAPERS"/*.jpg "$SYSTEM_WALLPAPERS"/*.jpeg "$SYSTEM_WALLPAPERS"/*.webp)
    
    if [[ ${#files[@]} -eq 0 ]]; then
        log "ERROR: No wallpapers found in $SYSTEM_WALLPAPERS"
        return
    fi
    
    local shuffled
    shuffled=$(printf '%s\n' "${files[@]}" | shuf)
    
    local inserted=0
    while IFS= read -r file; do
        local escaped="${file//\'/\'\'}"
        if sqlite3 "$DB_PATH" "INSERT OR IGNORE INTO wallpapers(path) VALUES('$escaped');" 2>/dev/null; then
            ((inserted++)) || true
        fi
    done <<< "$shuffled"
    
    log "Inserted $inserted wallpapers from system"
}

assign_random_wallpapers() {
    local max_ws=${1:-6}
    
    local wallpapers
    wallpapers=$(sqlite3 "$DB_PATH" "SELECT id FROM wallpapers" 2>/dev/null)
    
    if [[ -z "$wallpapers" ]]; then
        log "No wallpapers to assign"
        return 1
    fi
    
    local wallpapers_array
    IFS=$'\n' read -d '' -r -a wallpapers_array <<< "$wallpapers" || true
    local total=${#wallpapers_array[@]}
    
    if [[ $total -eq 0 ]]; then
        return
    fi
    
    for ws in $(seq 1 "$max_ws"); do
        local random_idx=$((RANDOM % total))
        local wallpaper_id="${wallpapers_array[$random_idx]}"
        local mode="fill"
        sqlite3 "$DB_PATH" "INSERT OR REPLACE INTO assignments(workspace, wallpaper_id, mode) VALUES($ws, $wallpaper_id, '$mode')" 2>/dev/null || true
    done
    
    log "Assigned random wallpapers to $max_ws workspaces"
}

detect_wm() {
    if [[ "${XDG_CURRENT_DESKTOP:-}" == *"sway"* ]] || command -v swaymsg >/dev/null 2>&1; then
        echo "sway"
    elif [[ "${XDG_CURRENT_DESKTOP:-}" == *"hypr"* ]] || command -v hyprctl >/dev/null 2>&1; then
        echo "hyprland"
    elif command -v swaymsg >/dev/null 2>&1; then
        echo "sway"
    elif command -v hyprctl >/dev/null 2>&1; then
        echo "hyprland"
    else
        echo "unknown"
    fi
}

get_current_workspace() {
    local wm=$1
    case "$wm" in
        sway)
            swaymsg -t get_workspaces 2>/dev/null | jq -r '.[] | select(.focused==true) | .num' 2>/dev/null || echo "1"
            ;;
        hyprland)
            hyprctl activeworkspace 2>/dev/null | grep -oP 'workspace ID \K\d+' || echo "1"
            ;;
        *)
            echo "1"
            ;;
    esac
}

get_wallpaper_for_workspace() {
    local ws=$1
    sqlite3 "$DB_PATH" "SELECT w.path FROM wallpapers w JOIN assignments a ON w.id = a.wallpaper_id WHERE a.workspace = $ws" 2>/dev/null || echo ""
}

get_mode_for_workspace() {
    local ws=$1
    sqlite3 "$DB_PATH" "SELECT a.mode FROM assignments a WHERE a.workspace = $ws" 2>/dev/null || echo "fill"
}

apply_wallpaper() {
    local wp=$1
    local mode=${2:-fill}
    
    if [[ -z "$wp" ]]; then
        log "apply_wallpaper: no wallpaper path provided"
        return 1
    fi
    
    if [[ ! -f "$wp" ]]; then
        log "apply_wallpaper: wallpaper not found: $wp"
        return 1
    fi
    
    log "Applying wallpaper: $wp (mode: $mode)"
    
    if command -v swww >/dev/null 2>&1; then
        if ! swww query >/dev/null 2>&1; then
            log "Starting swww-daemon..."
            swww-daemon &
            disown
            for _ in $(seq 1 30); do
                swww query >/dev/null 2>&1 && break
                sleep 0.3
            done
        fi
        swww img "$wp" --transition-type wipe --transition-duration 0.3 2>/dev/null || \
        swww img "$wp" 2>/dev/null || return 1
        sleep 0.5
    elif command -v swaybg >/dev/null 2>&1; then
        pkill -f "swaybg.*-i" 2>/dev/null || true
        swaybg -i "$wp" -m "$mode" &
    else
        log "ERROR: No wallpaper setter found (swww/swaybg)"
        return 1
    fi
    
    log "Wallpaper applied successfully"
}

handle_set() {
    local ws=$1
    local wp=$2
    local mode=${3:-}
    
    if [[ -z "$ws" ]]; then
        echo '{"error":"workspace required"}'
        return
    fi
    
    local wm current_ws
    wm=$(detect_wm)
    current_ws=$(get_current_workspace "$wm")
    
    log "handle_set: ws=$ws, wp=$wp, mode=$mode, current_ws=$current_ws"
    
    if [[ -n "$wp" && -f "$wp" ]]; then
        [[ -z "$mode" ]] && mode="fill"
        
        local wallpaper_id
        wallpaper_id=$(sqlite3 "$DB_PATH" "SELECT id FROM wallpapers WHERE path = '$wp'" 2>/dev/null | head -1)
        
        if [[ -z "$wallpaper_id" ]]; then
            local escaped="${wp//\'/\'\'}"
            sqlite3 "$DB_PATH" "INSERT INTO wallpapers(path) VALUES('$escaped')" 2>/dev/null || true
            wallpaper_id=$(sqlite3 "$DB_PATH" "SELECT id FROM wallpapers WHERE path = '$wp'" 2>/dev/null | head -1)
        fi
        
        if [[ -n "$wallpaper_id" ]]; then
            sqlite3 "$DB_PATH" "INSERT OR REPLACE INTO assignments(workspace, wallpaper_id, mode) VALUES($ws, $wallpaper_id, '$mode')" 2>/dev/null || true
            log "handle_set: updated DB for workspace $ws"
        fi
        
        if [[ "$ws" == "$current_ws" ]]; then
            log "handle_set: applying wallpaper for current workspace"
            apply_wallpaper "$wp" "$mode"
            echo "{\"ok\":true,\"applied\":true,\"workspace\":$ws}"
        else
            log "handle_set: not current workspace ($current_ws), not applying"
            echo "{\"ok\":true,\"applied\":false,\"workspace\":$ws}"
        fi
        return
    fi
    
    local db_wp db_mode
    db_wp=$(get_wallpaper_for_workspace "$ws")
    db_mode=$(get_mode_for_workspace "$ws")
    
    log "handle_set: no path provided, reading from DB: wp=$db_wp"
    
    if [[ -n "$db_wp" && -f "$db_wp" ]]; then
        apply_wallpaper "$db_wp" "$db_mode"
        echo "{\"ok\":true,\"applied\":true,\"workspace\":$ws,\"path\":\"$db_wp\",\"mode\":\"$db_mode\"}"
    else
        log "handle_set: no wallpaper in DB for workspace $ws"
        echo "{\"ok\":true,\"applied\":false,\"workspace\":$ws,\"error\":\"no wallpaper assigned\"}"
    fi
}

handle_list() {
    local result
    result=$(sqlite3 "$DB_PATH" "SELECT json_group_array(json_object('id', id, 'path', path)) FROM wallpapers" 2>/dev/null)
    if [[ -z "$result" || "$result" == "null" ]]; then
        echo '{"wallpapers":[]}'
    else
        echo "{\"wallpapers\":$result}"
    fi
}

handle_get() {
    local ws=$1
    
    if [[ -z "$ws" ]]; then
        echo '{"error":"workspace required"}'
        return
    fi
    
    local wp mode
    wp=$(get_wallpaper_for_workspace "$ws")
    mode=$(get_mode_for_workspace "$ws")
    
    if [[ -n "$wp" ]]; then
        echo "{\"workspace\":$ws,\"path\":\"$wp\",\"mode\":\"$mode\"}"
    else
        echo "{\"workspace\":$ws,\"path\":null,\"mode\":null}"
    fi
}

handle_current() {
    local wm
    wm=$(detect_wm)
    local ws
    ws=$(get_current_workspace "$wm")
    echo "{\"workspace\":$ws,\"wm\":\"$wm\"}"
}

watch_workspace_hyprland() {
    log "Hyprland workspace watcher started"
    local last_ws=""
    
    while true; do
        local ws
        ws=$(hyprctl activeworkspace 2>/dev/null | grep -oP 'workspace ID \K\d+' || echo "1")
        
        if [[ -z "$ws" || "$ws" == "null" ]]; then
            ws="1"
        fi
        
        if [[ "$ws" != "$last_ws" ]]; then
            log "Hyprland workspace changed: $last_ws -> $ws"
            
            local wp mode
            wp=$(get_wallpaper_for_workspace "$ws")
            mode=$(get_mode_for_workspace "$ws")
            
            if [[ -n "$wp" && -f "$wp" ]]; then
                apply_wallpaper "$wp" "$mode"
            else
                log "No wallpaper for workspace $ws (wp=$wp)"
            fi
            
            last_ws="$ws"
        fi
        
        sleep 0.5
    done
}

watch_workspace_sway() {
    log "Sway workspace watcher started"
    
    while read -r event; do
        local ws
        ws=$(echo "$event" | jq -r '.current.num' 2>/dev/null || echo "")
        
        if [[ -z "$ws" || "$ws" == "null" ]]; then
            continue
        fi
        
        log "Sway workspace event: $ws"
        
        local wp mode
        wp=$(get_wallpaper_for_workspace "$ws")
        mode=$(get_mode_for_workspace "$ws")
        
        if [[ -n "$wp" && -f "$wp" ]]; then
            apply_wallpaper "$wp" "$mode"
        else
            log "No wallpaper for workspace $ws"
        fi
        
    done < <(swaymsg -t subscribe -m '["workspace"]' 2>/dev/null)
}

start_daemon() {
    if [[ -f "$PID_FILE" ]]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
            log "Already running (PID: $old_pid)"
            exit 0
        fi
        rm -f "$PID_FILE"
    fi
    
    echo $$ > "$PID_FILE"
    log "Daemon starting (PID: $$)"
    
    init_db
    populate_from_system
    
    local count
    count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM assignments" 2>/dev/null || echo "0")
    if [[ "$count" -eq 0 ]]; then
        assign_random_wallpapers 6
    fi
    
    local wm
    wm=$(detect_wm)
    log "Starting daemon (WM: $wm)"
    
    case "$wm" in
        sway)
            watch_workspace_sway &
            ;;
        hyprland)
            watch_workspace_hyprland &
            ;;
    esac
    
    local current_ws wp mode
    current_ws=$(get_current_workspace "$wm")
    wp=$(get_wallpaper_for_workspace "$current_ws")
    mode=$(get_mode_for_workspace "$current_ws")
    
    log "Current workspace: $current_ws, wallpaper: $wp"
    
    if [[ -n "$wp" && -f "$wp" ]]; then
        apply_wallpaper "$wp" "$mode"
    fi
    
    log "Daemon ready"
    
    # Keep daemon alive
    while true; do
        sleep 60
    done
}

client_mode() {
    local cmd=$1
    shift
    
    init_db
    
    case "$cmd" in
        list)
            handle_list
            ;;
        get)
            local ws=${1:-}
            if [[ -z "$ws" ]]; then
                echo "Usage: $0 get <workspace>"
                exit 1
            fi
            handle_get "$ws"
            ;;
        set)
            local ws=${1:-}
            local wp=${2:-}
            local mode=${3:-fill}
            if [[ -z "$ws" ]]; then
                echo "Usage: $0 set <workspace> [path] [mode]"
                exit 1
            fi
            handle_set "$ws" "$wp" "$mode"
            ;;
        current)
            handle_current
            ;;
        *)
            echo "{\"error\":\"unknown command: $cmd\"}"
            exit 1
            ;;
    esac
}

case "${1:-}" in
    -d|--daemon|daemon)
        start_daemon
        ;;
    list|get|set|current)
        client_mode "$@"
        ;;
    *)
        echo "Usage: $0 <command>"
        echo "Commands:"
        echo "  list              - List all wallpapers in DB"
        echo "  get <workspace>   - Get wallpaper for workspace"
        echo "  set <ws> [path] [mode] - Set wallpaper for workspace"
        echo "  current           - Get current workspace"
        echo "  -d, --daemon     - Start daemon mode"
        exit 1
        ;;
esac
