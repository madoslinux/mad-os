#!/bin/bash
# snapper-pre-update - Creates a snapshot before pacman transactions
# This script is called by the pacman pre-update hook

set -e

SNAPPER_CONFIG="root"
TIMESTAMP=$(date +%s)
DESCRIPTION="pre-update-${TIMESTAMP}"

if command -v snapper &> /dev/null; then
    snapper create \
        -t pre \
        -c "${SNAPPER_CONFIG}" \
        -d "${DESCRIPTION}" \
        -p 2>/dev/null || true
fi

exit 0
